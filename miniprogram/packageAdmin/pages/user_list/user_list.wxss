/* Page Container */
.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f8fafc 0%, #ffffff 100%);
  display: flex;
  flex-direction: column;
}

/* Stats Summary Bar */
.stats-bar {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #ffffff 0%, #f0f9ff 100%);
  padding: 28rpx 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.04);
  border-bottom: 1rpx solid rgba(226, 232, 240, 0.5);
}

.sb-item {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.sb-value {
  font-size: 48rpx;
  font-weight: 950;
  color: #1e293b;
  line-height: 1;
  margin-bottom: 6rpx;
}

.sb-label {
  font-size: 22rpx;
  color: #64748b;
  font-weight: 600;
}

.sb-divider {
  width: 2rpx;
  height: 60rpx;
  background: linear-gradient(180deg, transparent 0%, #e2e8f0 50%, transparent 100%);
  margin: 0 24rpx;
}

.sb-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.sb-icon-wrap.normal { background: linear-gradient(135deg, #dcfce7 0%, #bbf7d0 100%); }
.sb-icon-wrap.late { background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%); }
.sb-icon-wrap.absent { background: linear-gradient(135deg, #fee2e2 0%, #fecaca 100%); }
.sb-icon-wrap.leave { background: linear-gradient(135deg, #ede9fe 0%, #ddd6fe 100%); }
.sb-icon-wrap.all { background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%); }

.sb-icon {
  filter: brightness(1.1);
}

/* List Scroll */
.list-scroll {
  flex: 1;
  height: 0;
}

.list-content {
  padding: 24rpx;
}

/* User Card */
.user-card {
  display: flex;
  align-items: center;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid rgba(241, 245, 249, 0.8);
  transition: all 0.2s ease;
  position: relative;
  overflow: hidden;
}

.user-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 4rpx;
  background: linear-gradient(180deg, #cbd5e1 0%, #e2e8f0 100%);
  opacity: 0;
  transition: opacity 0.2s ease;
}

.user-card:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.user-card:active::before {
  opacity: 1;
}

/* Left Section - Avatar */
.uc-left {
  margin-right: 20rpx;
  flex-shrink: 0;
}

.ucl-avatar-wrap {
  position: relative;
  width: 88rpx;
  height: 88rpx;
}

.ucl-avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: #f1f5f9;
  border: 3rpx solid #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.ucl-status {
  position: absolute;
  bottom: 2rpx;
  right: 2rpx;
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  border: 3rpx solid #ffffff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.ucl-status.normal { background: #22c55e; }
.ucl-status.late { background: #f59e0b; }
.ucl-status.absent { background: #ef4444; }
.ucl-status.leave { background: #a855f7; }

/* Center Section - Info */
.uc-center {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.ucc-top {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.ucc-name {
  font-size: 30rpx;
  font-weight: 800;
  color: #1e293b;
  flex-shrink: 0;
}

.ucc-tag {
  padding: 4rpx 14rpx;
  border-radius: 10rpx;
  font-size: 20rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.ucc-tag.normal { 
  background: linear-gradient(135deg, #dcfce7 0%, #bbf7d0 100%); 
  color: #166534; 
}
.ucc-tag.late { 
  background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%); 
  color: #92400e; 
}
.ucc-tag.absent { 
  background: linear-gradient(135deg, #fee2e2 0%, #fecaca 100%); 
  color: #991b1b; 
}
.ucc-tag.leave { 
  background: linear-gradient(135deg, #ede9fe 0%, #ddd6fe 100%); 
  color: #6b21a8; 
}

.ucc-dept {
  font-size: 22rpx;
  color: #94a3b8;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* Right Section - Arrow */
.uc-right {
  margin-left: 16rpx;
  flex-shrink: 0;
}

.ucr-arrow {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f8fafc;
  border-radius: 50%;
}

.ucr-arrow text {
  font-size: 32rpx;
  color: #cbd5e1;
  font-weight: 300;
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
}

.es-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
  opacity: 0.6;
}

.es-text {
  font-size: 28rpx;
  color: #64748b;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.es-hint {
  font-size: 22rpx;
  color: #cbd5e1;
  font-weight: 500;
}

/* 底部信息 */
.footer {
  position: relative;
  width: 100%;
  padding: 60rpx 0 40rpx;
  opacity: 0.6;
}

.footer-icon {
  position: absolute;
  width: 64rpx;
  height: 4rpx;
  left: 50%;
  top: 40rpx;
  transform: translateX(-50%);
}

.footer-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.footer-title {
  font-size: 24rpx;
  font-family: Inter, sans-serif;
  font-weight: 900;
  color: #0F172B;
  text-align: center;
  margin-bottom: 20rpx;
}

.footer-record {
  font-size: 20rpx;
  font-family: Inter, sans-serif;
  font-weight: 700;
  color: #62748E;
  text-align: center;
  margin-bottom: 16rpx;
}

.footer-copyright {
  font-size: 16rpx;
  font-family: Inter, sans-serif;
  font-weight: 500;
  color: #90A1B9;
  text-align: center;
}
