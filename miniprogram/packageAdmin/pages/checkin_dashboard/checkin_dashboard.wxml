<view class="container">
    <!-- Header Section -->
    <view class="page-header-v3">
                <view class="ph-floating-card">
                    <!-- Mesh Gradient Decoration -->
                    <view class="mesh-bg">
                        <view class="mesh-dot mesh-dot-1"></view>
                        <view class="mesh-dot mesh-dot-2"></view>
                        <view class="mesh-dot mesh-dot-3"></view>
                    </view>

                    <view class="ph-content">
                        <view class="ph-top">
                            <view class="pht-left" style="flex: 1;">
                                <text class="pht-label" style="font-size: 36rpx; color: #009966; font-weight: 900;">{{dashboardTitle || '签到数据看板'}}</text>
                            </view>
                            <view class="pht-right">
                                <view class="ph-icon-box">
                                    <image class="ph-icon-img" src="https://www.qjzxmd.cn/uploads/icons/v3_icon.png" mode="aspectFit"></image>
                                </view>
                            </view>
                        </view>
                    </view>

                    <!-- Tab Navigation (Segmented style) -->
                    <view class="tab-wrapper-v3">
                        <view class="tab-list">
                            <view wx:for="{{periods}}" wx:key="id"
                                  class="tab-item-v3 {{activePeriod === item.id ? 'active' : ''}}"
                                  bindtap="onPeriodChange" data-period="{{item.id}}">
                                {{item.label}}
                            </view>
                        </view>
                    </view>
                </view>
    </view>

    <!-- Main Content -->
    <view class="main-content">
        <!-- Overview Card -->
        <view class="overview-card">
            <view class="oc-header">
                <text class="och-title">出勤概览</text>
                <view class="och-badge {{badgeStatus}}">
                    {{badgeText}}
                </view>
            </view>

            <view class="oc-body">
                <view class="ocb-main">
                    <view class="ocbm-circle">
                        <view class="ocbmc-ring" style="background: conic-gradient(#00BC7D {{summary.rate}}%, #e8f5e9 0);"></view>
                        <view class="ocbmc-inner">
                            <text class="ocbmci-value">{{summary.rate}}</text>
                            <text class="ocbmci-unit">%</text>
                        </view>
                    </view>
                    <view class="ocbm-info">
                        <view class="ocbm-label-row">
                            <text class="ocbm-label">应到 {{summary.total}} 人</text>
                            <view class="ocbm-view-all" bindtap="goToUserList" data-type="total">
                                <text class="ocbm-va-text">查看全部</text>
                                <text class="ocbm-va-icon">›</text>
                            </view>
                        </view>
                        <text class="ocbm-desc">实到 {{summary.normal_count}} 人</text>
                    </view>
                </view>

                <view class="ocb-stats">
                    <view class="ocbs-item" bindtap="goToUserList" data-type="late">
                        <text class="ocbsi-label">迟到</text>
                        <text class="ocbsi-value">{{summary.late_count}}</text>
                    </view>
                    <view class="ocbs-divider"></view>
                    <view class="ocbs-item" bindtap="goToUserList" data-type="absent">
                        <text class="ocbsi-label">缺勤</text>
                        <text class="ocbsi-value">{{summary.absent_count}}</text>
                    </view>
                    <view class="ocbs-divider"></view>
                    <view class="ocbs-item" bindtap="goToUserList" data-type="leave">
                        <text class="ocbsi-label">请假</text>
                        <text class="ocbsi-value">{{summary.leave_count || 0}}</text>
                    </view>
                </view>
            </view>
        </view>

        <!-- Stats Grid -->
        <view class="stats-section">
            <view class="ss-card-v3" bindtap="goToUserList" data-type="normal">
                <view class="ssc-left">
                    <view class="ssc-icon-v3 green">✓</view>
                </view>
                <view class="ssc-right">
                    <text class="ssci-label">正常签到</text>
                    <view class="ssci-main">
                        <text class="ssci-value">{{summary.normal_count}}</text>
                        <text class="ssci-percent">{{percentages.normal}}%</text>
                    </view>
                    <view class="ssc-progress-v3">
                        <view class="sscp-bar-v3" style="width: {{percentages.normal}}%;"></view>
                    </view>
                </view>
            </view>

            <view class="ss-card-v3" bindtap="goToUserList" data-type="late">
                <view class="ssc-left">
                    <view class="ssc-icon-v3 orange">⚠</view>
                </view>
                <view class="ssc-right">
                    <text class="ssci-label">迟到人数</text>
                    <view class="ssci-main">
                        <text class="ssci-value">{{summary.late_count}}</text>
                        <text class="ssci-percent">{{percentages.late}}%</text>
                    </view>
                    <view class="ssc-progress-v3">
                        <view class="sscp-bar-v3 orange" style="width: {{percentages.late}}%;"></view>
                    </view>
                </view>
            </view>

            <view class="ss-card-v3" bindtap="goToUserList" data-type="absent">
                <view class="ssc-left">
                    <view class="ssc-icon-v3 red">✗</view>
                </view>
                <view class="ssc-right">
                    <text class="ssci-label">缺勤预警</text>
                    <view class="ssci-main">
                        <text class="ssci-value">{{summary.absent_count}}</text>
                        <text class="ssci-percent">{{percentages.absent}}%</text>
                    </view>
                    <view class="ssc-progress-v3">
                        <view class="sscp-bar-v3 red" style="width: {{percentages.absent}}%;"></view>
                    </view>
                </view>
            </view>

            <view class="ss-card-v3" bindtap="goToUserList" data-type="leave">
                <view class="ssc-left">
                    <view class="ssc-icon-v3 purple">🏠</view>
                </view>
                <view class="ssc-right">
                    <text class="ssci-label">请假审批</text>
                    <view class="ssci-main">
                        <text class="ssci-value">{{summary.leave_count || 0}}</text>
                        <text class="ssci-percent">{{percentages.leave}}%</text>
                    </view>
                    <view class="ssc-progress-v3">
                        <view class="sscp-bar-v3 purple" style="width: {{percentages.leave}}%;"></view>
                    </view>
                </view>
            </view>
        </view>

        <!-- Abnormal List -->
        <view class="abnormal-section" wx:if="{{categories && (categories.absent.length > 0 || categories.late.length > 0)}}">
            <view class="abs-header">
                <view class="abh-left">
                    <text class="abh-title">异常名单</text>
                    <view class="abh-badge">{{categories.absent.length + categories.late.length}}</view>
                </view>
            </view>

            <view class="abs-list">
                <view class="abl-item" wx:for="{{categories.absent}}" wx:key="id" wx:if="{{item.real_name}}">
                    <view class="abli-avatar">
                        <image class="abli-avatar-img" src="{{item.display_avatar}}" mode="aspectFill"></image>
                    </view>
                    <view class="abli-info">
                        <text class="abli-name">{{item.real_name}}</text>
                        <text class="abli-dept">{{item.department || ''}}</text>
                    </view>
                    <view class="abli-tag red" bindtap="goToUserDetail" data-id="{{item.id}}">未签到</view>
                </view>

                <view class="abl-item" wx:for="{{categories.late}}" wx:key="id" wx:if="{{item.real_name}}">
                    <view class="abli-avatar">
                        <image class="abli-avatar-img" src="{{item.display_avatar}}" mode="aspectFill"></image>
                    </view>
                    <view class="abli-info">
                        <text class="abli-name">{{item.real_name}}</text>
                        <text class="abli-dept">{{item.department || ''}}</text>
                    </view>
                    <view class="abli-tag orange" bindtap="goToUserDetail" data-id="{{item.id}}">迟到 ×{{item.late_count || 0}}</view>
                </view>
            </view>
        </view>

        <!-- Normal List -->
        <view class="normal-section" wx:if="{{categories}}">
            <view class="ns-header" bindtap="toggleCategory" data-cat="normal">
                <view class="nsh-left">
                    <text class="nsh-title">正常签到</text>
                    <text class="nsh-count">{{summary.normal_count}}人</text>
                </view>
                <view class="nsh-arrow {{expanded.normal ? 'up' : 'down'}}">
                    <text>▼</text>
                </view>
            </view>

            <view class="ns-grid" wx:if="{{expanded.normal}}">
                <view class="nsg-item" wx:for="{{categories.normal}}" wx:key="id" wx:if="{{item.real_name}}" bindtap="goToUserDetail" data-id="{{item.id}}">
                    {{item.real_name}}
                </view>
            </view>
        </view>
    </view>

    <!-- Logout Action -->
    <view class="action-section">
        <view class="logout-btn" bindtap="onLogout">
            <text class="logout-icon">🔓</text>
            <text class="logout-text">退出当前账户</text>
        </view>
    </view>

    <!-- Page Footer -->
    <view class="footer">
        <image class="footer-icon" src="/assets/CodeBubbyAssets/2_509/1.svg" mode="aspectFit"></image>
        <view class="footer-content">
            <text class="footer-title">海亮教育·清涧中学教师数字化管理平台</text>
            <text class="footer-record">陕ICP备202506048号</text>
            <text class="footer-copyright">版权所有 © 2024-2026 TD 数字科技。保留所有权利。</text>
        </view>
    </view>
    <!-- Loading -->
    <view class="loading-mask" wx:if="{{loading}}">
        <view class="loader"></view>
    </view>
</view>
