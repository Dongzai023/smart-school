/* Container */
.container {
    /* min-height: 100vh; */
    background: linear-gradient(180deg, #f0f9f5 0%, #ffffff 100%);
    padding-bottom: 40rpx;
    box-sizing: border-box;
    display: block !important;
    align-items: flex-start !important;
    width: 100%;
    /* margin: 0; */
}

/* Header V3 */
.page-header-v3 {
    padding: 20rpx 28rpx 20rpx;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
}

.ph-floating-card {
    background: rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(40rpx);
    border: 1px solid rgba(255, 255, 255, 0.4);
    border-radius: 48rpx;
    padding: 32rpx;
    box-shadow: 0 16rpx 64rpx rgba(0, 0, 0, 0.1);
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 32rpx;
}

/* Mesh Background */
.mesh-bg {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 0;
}

.mesh-dot {
    position: absolute;
    border-radius: 50%;
    filter: blur(80rpx);
    opacity: 0.4;
    animation: pulse 8s infinite alternate;
}

.mesh-dot-1 {
    top: -50rpx;
    right: -50rpx;
    width: 300rpx;
    height: 300rpx;
    background: #00BC7D;
}

.mesh-dot-2 {
    bottom: -80rpx;
    left: -80rpx;
    width: 250rpx;
    height: 250rpx;
    background: #4ade80;
    animation-delay: -2s;
}

.mesh-dot-3 {
    top: 50%;
    left: 40%;
    width: 200rpx;
    height: 200rpx;
    background: #2dd4bf;
    animation-delay: -4s;
}

@keyframes pulse {
    0% { transform: scale(1); opacity: 0.3; }
    100% { transform: scale(1.3); opacity: 0.5; }
}

.ph-content {
    position: relative;
    z-index: 1;
}

.ph-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.pht-left {
    flex: 1;
}

.ph-title {
    font-size: 44rpx;
    font-weight: 800;
    color: #0f172a;
    display: block;
    margin-bottom: 4rpx;
    letter-spacing: -0.5rpx;
}

.ph-subtitle {
    font-size: 20rpx;
    font-weight: 600;
    color: #64748b;
    display: block;
    letter-spacing: 2rpx;
    text-transform: uppercase;
}

.pht-right {
    width: 96rpx;
    height: 96rpx;
    display: flex;
    align-items: center;
    justify-content: center;
}

.ph-icon-box {
    width: 96rpx;
    height: 96rpx;
    background: rgba(0, 188, 125, 0.1);
    border-radius: 32rpx;
    display: flex;
    align-items: center;
    justify-content: center;
}

.ph-icon-img {
    width: 80rpx;
    height: 80rpx;
}

/* Tab V3 (Segmented) */
.tab-wrapper-v3 {
    background: rgba(241, 245, 249, 0.8);
    border-radius: 24rpx;
    padding: 6rpx;
    position: relative;
    z-index: 1;
}

.tab-list {
    display: flex;
    gap: 0;
}

.tab-item-v3 {
    flex: 1;
    text-align: center;
    padding: 16rpx 0;
    font-size: 26rpx;
    font-weight: 700;
    color: #64748b;
    transition: all 0.3s ease;
    border-radius: 20rpx;
}

.tab-item-v3.active {
    background: #ffffff;
    color: #00BC7D;
    box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

/* Main Content */
.main-content {
    padding: 24rpx;
    margin-top: 100rpx;
    position: relative;
    z-index: 2;
}

/* Overview Card */
.overview-card {
    background: linear-gradient(135deg, #ffffff 0%, #f0fdfa 100%);
    border-radius: 32rpx;
    padding: 28rpx;
    box-shadow: 0 12rpx 40rpx rgba(0, 188, 125, 0.15);
    margin-bottom: 20rpx;
    position: relative;
    overflow: hidden;
    border: 2rpx solid rgba(255, 255, 255, 0.9);
}

.overview-card::before {
    content: '';
    position: absolute;
    top: -80rpx;
    right: -80rpx;
    width: 240rpx;
    height: 240rpx;
    background: radial-gradient(circle, rgba(0, 188, 125, 0.08) 0%, transparent 70%);
    filter: blur(40rpx);
}

.overview-card::after {
    content: '';
    position: absolute;
    bottom: -60rpx;
    left: -60rpx;
    width: 200rpx;
    height: 200rpx;
    background: radial-gradient(circle, rgba(34, 211, 238, 0.06) 0%, transparent 70%);
    filter: blur(40rpx);
}

.oc-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 32rpx;
    position: relative;
    z-index: 1;
}

.och-title {
    font-size: 32rpx;
    font-weight: 800;
    color: #1e293b;
}

.och-badge {
    padding: 8rpx 20rpx;
    border-radius: 12rpx;
    font-size: 22rpx;
    font-weight: 700;
}

.och-badge.excellent {
    background: #dcfce7;
    color: #166534;
}

.och-badge.good {
    background: #fef3c7;
    color: #92400e;
}

.och-badge.warning {
    background: #fee2e2;
    color: #991b1b;
}

.oc-body {
    display: flex;
    flex-direction: column;
    gap: 32rpx;
    position: relative;
    z-index: 1;
}

.ocb-main {
    display: flex;
    align-items: center;
    gap: 32rpx;
}

.ocbm-circle {
    width: 160rpx;
    height: 160rpx;
    flex-shrink: 0;
    position: relative;
}

.ocbmc-ring {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    transition: background 0.6s ease;
}

.ocbmc-inner {
    position: absolute;
    top: 16rpx;
    left: 16rpx;
    right: 16rpx;
    bottom: 16rpx;
    background: #ffffff;
    border-radius: 50%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
}

.ocbmci-value {
    font-size: 48rpx;
    font-weight: 950;
    color: #00BC7D;
    line-height: 1;
}

.ocbmci-unit {
    font-size: 20rpx;
    color: #94a3b8;
    font-weight: 600;
}

.ocbm-info {
    flex: 1;
}

.ocbm-label-row {
    display: flex;
    justify-content: flex-start;
    align-items: center;
    gap: 16rpx;
    margin-bottom: 12rpx;
}

.ocbm-label {
    font-size: 28rpx;
    font-weight: 700;
    color: #1e293b;
}

.ocbm-view-all {
    display: flex;
    align-items: center;
    gap: 4rpx;
    padding: 8rpx 16rpx;
    background: rgba(0, 188, 125, 0.08);
    border-radius: 100rpx;
    transition: all 0.2s ease;
}

.ocbm-view-all:active {
    opacity: 0.7;
    transform: scale(0.95);
}

.ocbm-va-text {
    font-size: 20rpx;
    color: #00BC7D;
    font-weight: 700;
}

.ocbm-va-icon {
    font-size: 24rpx;
    color: #00BC7D;
    font-weight: 800;
    margin-top: -2rpx;
}

.ocbm-desc {
    font-size: 24rpx;
    font-weight: 600;
    color: #64748b;
}

.ocb-stats {
    display: flex;
    align-items: center;
    justify-content: space-around;
    padding-top: 24rpx;
    border-top: 2rpx solid #f1f5f9;
}

.ocbs-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8rpx;
}

.ocbsi-label {
    font-size: 22rpx;
    color: #64748b;
    font-weight: 600;
}

.ocbsi-value {
    font-size: 36rpx;
    font-weight: 950;
    color: #1e293b;
}

.ocbs-divider {
    width: 2rpx;
    height: 40rpx;
    background: #e2e8f0;
}

/* Stat Section V3 */
.stats-section {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20rpx;
    margin-bottom: 24rpx;
}

.ss-card-v3 {
    background: #ffffff;
    border-radius: 32rpx;
    padding: 24rpx;
    display: flex;
    gap: 20rpx;
    box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
    border: 1px solid rgba(241, 245, 249, 1);
}

.ssc-left {
    flex-shrink: 0;
}

.ssc-icon-v3 {
    width: 72rpx;
    height: 72rpx;
    border-radius: 20rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 32rpx;
    font-weight: 700;
}

.ssc-icon-v3.green { background: #f0fdf4; color: #10b981; }
.ssc-icon-v3.orange { background: #fffbeb; color: #f59e0b; }
.ssc-icon-v3.red { background: #fef2f2; color: #ef4444; }
.ssc-icon-v3.purple { background: #f5f3ff; color: #8b5cf6; }

.ssc-right {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
}

.ssci-label {
    font-size: 22rpx;
    font-weight: 600;
    color: #64748b;
    margin-bottom: 6rpx;
}

.ssci-main {
    display: flex;
    align-items: baseline;
    gap: 8rpx;
    margin-bottom: 12rpx;
}

.ssci-value {
    font-size: 40rpx;
    font-weight: 800;
    color: #0f172a;
}

.ssci-percent {
    font-size: 20rpx;
    font-weight: 700;
    color: #94a3b8;
}

.ssc-progress-v3 {
    height: 8rpx;
    background: #f1f5f9;
    border-radius: 4rpx;
    overflow: hidden;
}

.sscp-bar-v3 {
    height: 100%;
    border-radius: 4rpx;
    transition: width 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.sscp-bar-v3 { background: #10b981; }
.sscp-bar-v3.orange { background: #f59e0b; }
.sscp-bar-v3.red { background: #ef4444; }
.sscp-bar-v3.purple { background: #8b5cf6; }

/* Abnormal Section */
.abnormal-section {
    background: #ffffff;
    border-radius: 24rpx;
    padding: 24rpx;
    box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
    margin-bottom: 24rpx;
}

.abs-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20rpx;
}

.abh-left {
    display: flex;
    align-items: center;
    gap: 12rpx;
}

.abh-title {
    font-size: 28rpx;
    font-weight: 800;
    color: #1e293b;
}

.abh-badge {
    background: #fee2e2;
    color: #ef4444;
    padding: 4rpx 16rpx;
    border-radius: 12rpx;
    font-size: 20rpx;
    font-weight: 700;
}

.abs-list {
    display: flex;
    flex-direction: column;
    gap: 16rpx;
}

.abl-item {
    display: flex;
    align-items: center;
    background: #f8fafc;
    border-radius: 16rpx;
    padding: 20rpx;
}

.abli-avatar {
    width: 72rpx;
    height: 72rpx;
    background: #e2e8f0;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-right: 16rpx;
    overflow: hidden;
    flex-shrink: 0;
}

.abli-avatar-img {
    width: 100%;
    height: 100%;
    border-radius: 50%;
}

.abli-avatar-text {
    font-size: 28rpx;
    font-weight: 800;
    color: #64748b;
}

.abli-info {
    flex: 1;
    display: flex;
    flex-direction: column;
}

.abli-name {
    font-size: 26rpx;
    font-weight: 700;
    color: #1e293b;
    margin-bottom: 4rpx;
}

.abli-dept {
    font-size: 22rpx;
    font-weight: 600;
    color: #94a3b8;
}

.abli-tag {
    padding: 8rpx 16rpx;
    border-radius: 8rpx;
    font-size: 20rpx;
    font-weight: 700;
}

.abli-tag.red { background: #fee2e2; color: #ef4444; }
.abli-tag.orange { background: #fef3c7; color: #f59e0b; }

/* Normal Section */
.normal-section {
    background: #ffffff;
    border-radius: 24rpx;
    padding: 24rpx;
    box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.ns-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-bottom: 20rpx;
    border-bottom: 2rpx solid #f1f5f9;
}

.nsh-left {
    display: flex;
    align-items: center;
    gap: 16rpx;
}

.nsh-title {
    font-size: 28rpx;
    font-weight: 800;
    color: #1e293b;
}

.nsh-count {
    font-size: 22rpx;
    font-weight: 700;
    color: #00BC7D;
}

.nsh-arrow {
    width: 24rpx;
    height: 24rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.3s ease;
}

.nsh-arrow.up { transform: rotate(180deg); }
.nsh-arrow.down { transform: rotate(0deg); }

.nsh-arrow text {
    color: #94a3b8;
    font-size: 16rpx;
}

.ns-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 12rpx;
    padding-top: 20rpx;
}

.nsg-item {
    background: #f0f9f5;
    color: #00BC7D;
    padding: 12rpx 24rpx;
    border-radius: 12rpx;
    font-size: 24rpx;
    font-weight: 700;
}

/* Logout Action */
.action-section {
    padding: 0 48rpx 40rpx;
    margin-top: 20rpx;
}

.logout-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16rpx;
    background: rgba(254, 226, 226, 0.5);
    border: 2rpx solid rgba(252, 165, 165, 0.3);
    border-radius: 28rpx;
    padding: 24rpx;
    transition: all 0.2s ease;
}

.logout-btn:active {
    transform: scale(0.98);
    background: rgba(254, 202, 202, 0.8);
}

.logout-icon {
    font-size: 32rpx;
}

.logout-text {
    font-size: 28rpx;
    font-weight: 800;
    color: #dc2626;
    letter-spacing: 1rpx;
}

/* Loading */
.loading-mask {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(255, 255, 255, 0.9);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 9999;
}

.loader {
    width: 60rpx;
    height: 60rpx;
    border: 6rpx solid #e2e8f0;
    border-top-color: #00BC7D;
    border-radius: 50%;
    animation: spin 1s linear infinite;
}

@keyframes spin {
    to { transform: rotate(360deg); }
}
/* Footer Info (Copied from index.wxss) */
.footer {
    position: relative;
    width: 100%;
    height: 300rpx;
    opacity: 0.6; /* Increased slightly for better visibility on white background */
    padding-bottom: 60rpx;
    margin-top: 40rpx;
}

.footer-icon {
    position: absolute;
    width: 64rpx;
    height: 4rpx;
    left: 50%;
    top: 60rpx;
    transform: translateX(-50%);
}

.footer-content {
    position: absolute;
    top: 94rpx;
    left: 0;
    right: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
}

.footer-title {
    font-size: 24rpx;
    font-family: Inter, sans-serif;
    font-weight: 900;
    color: #0F172B;
    text-align: center;
    margin-bottom: 12rpx;
}

.footer-record {
    font-size: 20rpx;
    font-family: Inter, sans-serif;
    font-weight: 700;
    color: #62748E;
    text-align: center;
    margin-bottom: 8rpx;
}

.footer-copyright {
    font-size: 16rpx;
    font-family: Inter, sans-serif;
    font-weight: 500;
    color: #90A1B9;
    text-align: center;
}
