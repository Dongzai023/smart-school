/* Page Container */
.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f8fafc 0%, #ffffff 100%);
  display: flex;
  flex-direction: column;
}

/* User Profile Header */
.profile-header {
  position: relative;
  padding: 32rpx 32rpx 40rpx;
  background: linear-gradient(135deg, #00BC7D 0%, #059669 100%);
  overflow: hidden;
}

.ph-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: radial-gradient(circle at 80% 20%, rgba(255, 255, 255, 0.15) 0%, transparent 60%);
}

.ph-content {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.phc-avatar-wrap {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  flex-shrink: 0;
}

.phc-avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 255, 255, 0.3);
  background: rgba(255, 255, 255, 0.1);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.phc-status {
  position: absolute;
  bottom: 4rpx;
  right: 4rpx;
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  border: 4rpx solid #00BC7D;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.phc-status.normal { background: #22c55e; }
.phc-status.late { background: #f59e0b; }
.phc-status.absent { background: #ef4444; }
.phc-status.leave { background: #a855f7; }

.phc-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.phc-name {
  font-size: 40rpx;
  font-weight: 950;
  color: #ffffff;
  letter-spacing: 1rpx;
}

.phc-dept {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(10rpx);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  align-self: flex-start;
}

.phcd-icon {
  font-size: 20rpx;
}

.phcd-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.95);
  font-weight: 600;
}

/* Stats Summary */
.stats-summary {
  display: flex;
  align-items: center;
  background: #ffffff;
  margin: -20rpx 24rpx 0;
  border-radius: 24rpx;
  padding: 28rpx 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 188, 125, 0.15);
  position: relative;
  z-index: 2;
}

.ss-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.ssi-value {
  font-size: 44rpx;
  font-weight: 950;
  color: #1e293b;
  line-height: 1;
}

.ssi-value.success { color: #10b981; }
.ssi-value.warning { color: #f59e0b; }
.ssi-value.danger { color: #ef4444; }

.ssi-label {
  font-size: 20rpx;
  color: #94a3b8;
  font-weight: 600;
}

.ss-divider {
  width: 2rpx;
  height: 50rpx;
  background: linear-gradient(180deg, transparent 0%, #e2e8f0 50%, transparent 100%);
}

/* Records Section */
.records-section {
  flex: 1;
  padding: 32rpx 24rpx;
}

.rs-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding: 0 8rpx;
}

.rsh-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #1e293b;
}

.rsh-period {
  font-size: 22rpx;
  font-weight: 700;
  color: #00BC7D;
  background: linear-gradient(135deg, #d1fae5 0%, #a7f3d0 100%);
  padding: 8rpx 20rpx;
  border-radius: 16rpx;
}

/* Record List */
.rs-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.record-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

/* Left - Date */
.ri-left {
  width: 80rpx;
  flex-shrink: 0;
}

/* Right - Slots Row */
.ri-right {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
}

.rislots-row {
  display: flex;
  flex-wrap: nowrap;
  gap: 12rpx;
  width: 100%;
}

.ril-date {
  display: flex;
  justify-content: center;
  align-items: center;
  background: linear-gradient(135deg, #f1f5f9 0%, #e2e8f0 100%);
  padding: 10rpx 12rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.04);
}

.ril-datestr {
  font-size: 24rpx;
  font-weight: 800;
  color: #475569;
  letter-spacing: -1rpx;
}

.rislot {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 10rpx 4rpx;
  border-radius: 12rpx;
  background: #f8fafc;
  border: 1rpx solid #f1f5f9;
  min-width: 0;
}

.rislot-label {
  font-size: 18rpx;
  color: #94a3b8;
  font-weight: 600;
  margin-bottom: 4rpx;
}

.rislot-time {
  font-size: 24rpx;
  font-weight: 800;
  color: #1e293b;
}

/* Slot Status Colors */
.rislot.normal {
  background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%);
  border-color: #bbf7d0;
}
.rislot.normal .rislot-time { color: #166534; }

.rislot.late {
  background: linear-gradient(135deg, #fffbeb 0%, #fef3c7 100%);
  border-color: #fde68a;
}
.rislot.late .rislot-time { color: #92400e; }

.rislot.absent {
  background: linear-gradient(135deg, #fff1f2 0%, #fee2e2 100%);
  border-color: #fecaca;
}
.rislot.absent .rislot-time { color: #991b1b; }
 
.rislot.pending {
  background: #f1f5f9;
  border-color: #e2e8f0;
}
.rislot.pending .rislot-time { color: #94a3b8; }

.ril-weekday {
  font-size: 20rpx;
  color: #64748b;
  font-weight: 600;
  margin-top: 8rpx;
  text-align: center;
}

.rircb-icon {
  font-size: 20rpx;
}

.rircb-location {
  font-size: 22rpx;
  color: #64748b;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.es-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.es-text {
  font-size: 26rpx;
  color: #94a3b8;
  font-weight: 600;
}

/* 底部信息 */
.footer {
  position: relative;
  width: 100%;
  padding: 60rpx 0 80rpx;
  opacity: 0.6;
}

.footer-icon {
  position: absolute;
  width: 64rpx;
  height: 4rpx;
  left: 50%;
  top: 40rpx;
  transform: translateX(-50%);
}

.footer-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.footer-title {
  font-size: 24rpx;
  font-family: Inter, sans-serif;
  font-weight: 900;
  color: #0F172B;
  text-align: center;
  margin-bottom: 20rpx;
}

.footer-record {
  font-size: 20rpx;
  font-family: Inter, sans-serif;
  font-weight: 700;
  color: #62748E;
  text-align: center;
  margin-bottom: 16rpx;
}

.footer-copyright {
  font-size: 16rpx;
  font-family: Inter, sans-serif;
  font-weight: 500;
  color: #90A1B9;
  text-align: center;
}
