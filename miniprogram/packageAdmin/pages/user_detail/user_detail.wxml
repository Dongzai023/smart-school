<view class="page-container">
  <!-- User Profile Header -->
  <view class="profile-header">
    <view class="ph-bg"></view>
    <view class="ph-content">
      <view class="phc-avatar-wrap">
        <image class="phc-avatar" src="{{user.display_avatar}}" mode="aspectFill"></image>
        <view class="phc-status {{user.statusClass}}"></view>
      </view>
      <view class="phc-info">
        <text class="phc-name">{{user.name}}</text>
        <view class="phc-dept">
          <text class="phcd-icon">👥</text>
          <text class="phcd-text">{{user.department}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Stats Summary -->
  <view class="stats-summary">
    <view class="ss-item">
      <text class="ssi-value">{{stats.total}}</text>
      <text class="ssi-label">总打卡</text>
    </view>
    <view class="ss-divider"></view>
    <view class="ss-item">
      <text class="ssi-value success">{{stats.normal}}</text>
      <text class="ssi-label">正常</text>
    </view>
    <view class="ss-divider"></view>
    <view class="ss-item">
      <text class="ssi-value warning">{{stats.late}}</text>
      <text class="ssi-label">迟到</text>
    </view>
    <view class="ss-divider"></view>
    <view class="ss-item">
      <text class="ssi-value danger">{{stats.absent}}</text>
      <text class="ssi-label">缺勤</text>
    </view>
  </view>

  <!-- Records List -->
  <view class="records-section">
    <view class="rs-header">
      <text class="rsh-title">考勤记录</text>
      <text class="rsh-period">{{periodLabel}}</text>
    </view>

    <view class="rs-list">
      <view class="record-item" wx:for="{{records}}" wx:key="id">
        <!-- 左侧日期 -->
        <view class="ri-left">
          <view class="ril-date">
            <text class="ril-datestr">{{item.dateStr}}</text>
          </view>
          <text class="ril-weekday">{{item.weekday}}</text>
        </view>

        <!-- 连接线 -->
        <view class="ri-center">
          <view class="ric-line">
            <view class="ric-dot {{item.statusClass}}"></view>
          </view>
        </view>

        <!-- 右侧：4个时段一行 -->
        <view class="ri-right">
          <view class="rislots-row">
            <view class="rislot {{slot.statusClass}}" wx:for="{{item.slots}}" wx:key="label" wx:for-item="slot">
              <text class="rislot-label">{{slot.label}}</text>
              <text class="rislot-time">{{slot.time}}</text>
            </view>
          </view>
        </view>
      </view>

      <!-- Empty State -->
      <view class="empty-state" wx:if="{{records.length === 0}}">
        <view class="es-icon">📋</view>
        <text class="es-text">该时段暂无考勤记录</text>
      </view>
    </view>
  </view>

  <!-- 底部信息 -->
  <view class="footer">
    <image class="footer-icon" src="/assets/CodeBubbyAssets/2_509/1.svg" mode="aspectFit"></image>
    <view class="footer-content">
      <text class="footer-title">海亮教育·清涧中学教师数字化管理平台</text>
      <text class="footer-record">陕ICP备202506048号</text>
      <text class="footer-copyright">版权所有 © 2024-2026 TD 数字科技。保留所有权利。</text>
    </view>
  </view>
</view>
