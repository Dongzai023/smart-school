<!-- pages/scan-unlock/scan-unlock.wxml -->
<view class="container">

  <!-- 加载中 -->
  <view class="status-card" wx:if="{{status === 'loading'}}">
    <view class="icon-wrapper loading-ring">
      <text class="icon">⏳</text>
    </view>
    <text class="title">正在解锁</text>
    <text class="message">{{message || '请稍候...'}}</text>
  </view>

  <!-- 解锁成功 -->
  <view class="status-card success" wx:if="{{status === 'success'}}">
    <view class="icon-wrapper success-bg">
      <text class="icon">✅</text>
    </view>
    <text class="title">解锁成功</text>
    <text class="message">{{message}}</text>
    <text class="device-name" wx:if="{{deviceName}}">设备：{{deviceName}}</text>
    <button class="btn btn-primary" bindtap="goHome">返回首页</button>
  </view>

  <!-- 无权限 -->
  <view class="status-card no-permission" wx:if="{{status === 'no_permission'}}">
    <view class="icon-wrapper warning-bg">
      <text class="icon">🚫</text>
    </view>
    <text class="title">无法解锁</text>
    <text class="message">{{message}}</text>
    <button class="btn btn-secondary" bindtap="goHome">返回首页</button>
  </view>

  <!-- 未登录 -->
  <view class="status-card no-login" wx:if="{{status === 'no_login'}}">
    <view class="icon-wrapper warning-bg">
      <text class="icon">🔑</text>
    </view>
    <text class="title">请先登录</text>
    <text class="message">{{message}}</text>
    <button class="btn btn-primary" bindtap="goLogin">去登录</button>
  </view>

  <!-- 错误 -->
  <view class="status-card error" wx:if="{{status === 'error'}}">
    <view class="icon-wrapper error-bg">
      <text class="icon">❌</text>
    </view>
    <text class="title">解锁失败</text>
    <text class="message">{{message}}</text>
    <view class="btn-group">
      <button class="btn btn-primary" bindtap="onRetry">重试</button>
      <button class="btn btn-secondary" bindtap="goHome">返回首页</button>
    </view>
  </view>

</view>
