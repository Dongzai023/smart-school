/* Global Page Reset - Prevent any default squeezing */
page {
  background-color: #f8fafc;
  height: 100vh;
  width: 100vw;
  overflow: hidden;
  display: block; /* Ensure no external flex interferes */
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
}

.app-root {
  display: flex;
  flex-direction: column;
  height: 100vh;
  width: 100vw;
  background-color: #f8fafc;
}

/* 1. Header (Light Theme) */
.app-header-light {
  flex: none;
  background-color: #ffffff;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #f1f5f9;
  z-index: 10;
}

.status-bar-filler {
  height: calc(24rpx + env(safe-area-inset-top));
}

.header-main {
  padding: 24rpx 40rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.title-group {
  display: flex;
  flex-direction: column;
}

.title-row {
  display: flex;
  align-items: center;
  margin-bottom: 6rpx;
}

.title-dot {
  width: 8rpx;
  height: 32rpx;
  background: #00BC7D;
  border-radius: 4rpx;
  margin-right: 16rpx;
}

.title-primary {
  font-size: 38rpx;
  font-weight: 800;
  color: #0f172a;
  letter-spacing: 1rpx;
}

.title-secondary {
  font-size: 22rpx;
  color: #94a3b8;
  margin-left: 24rpx; /* Offset for the dot width */
}

.sync-indicator {
  display: flex;
  align-items: center;
  background: #f0fdf4;
  padding: 10rpx 24rpx;
  border-radius: 100rpx;
}

.pulse-dot {
  width: 12rpx;
  height: 12rpx;
  background: #10b981;
  border-radius: 50%;
  margin-right: 12rpx;
  box-shadow: 0 0 10rpx #10b981;
  animation: dot-pulse 2s infinite ease-in-out;
}

@keyframes dot-pulse {
  0% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.3); opacity: 0.6; }
  100% { transform: scale(1); opacity: 1; }
}

.sync-indicator text {
  font-size: 18rpx;
  color: #10b981;
  font-weight: 700;
}

.tab-scroller {
  padding: 8rpx 40rpx 8rpx;
}

.tab-nav-light {
  position: relative;
  background: #f1f5f9;
  height: 76rpx;
  border-radius: 20rpx;
  display: flex;
  padding: 6rpx;
  overflow: hidden;
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #64748b;
  z-index: 2;
  transition: all 0.3s;
}

.tab-item.active {
  color: #00BC7D;
  font-weight: 800;
}

.tab-active-bg-light {
  position: absolute;
  top: 6rpx;
  bottom: 6rpx;
  width: 33.33%;
  background: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  border-radius: 16rpx;
  transition: left 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  z-index: 1;
}

/* 2. Body (Flexible, Scrollable) */
.app-body {
  flex: 1;
  height: 0;
  width: 100%;
}

.body-content {
  padding: 32rpx 32rpx 120rpx;
  box-sizing: border-box;
}

/* Hero Attendance Card */
.hero-card {
  background: linear-gradient(135deg, #ffffff 0%, #f8fafc 100%);
  border-radius: 40rpx;
  padding: 44rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 20rpx 60rpx rgba(30, 41, 59, 0.08), 0 0 0 1rpx rgba(255, 255, 255, 0.9);
  position: relative;
  overflow: hidden;
}

.hero-card::before {
  content: '';
  position: absolute;
  top: 0;
  right: 0;
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(14, 165, 233, 0.08) 0%, transparent 70%);
  filter: blur(40rpx);
}

.hero-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 36rpx;
  position: relative;
  z-index: 1;
}

.rate-box {
  display: flex;
  flex-direction: column;
}

.label {
  font-size: 24rpx;
  color: #64748b;
  font-weight: 600;
  letter-spacing: 0.5rpx;
}

.num-row {
  display: flex;
  align-items: baseline;
  margin-top: 12rpx;
}

.big-val {
  font-size: 88rpx;
  font-weight: 950;
  background: linear-gradient(135deg, #0f172a 0%, #334155 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  line-height: 1;
}

.unit {
  font-size: 32rpx;
  color: #cbd5e1;
  margin-left: 8rpx;
  font-weight: 700;
}

.rate-badge {
  font-size: 18rpx;
  font-weight: 800;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  margin-top: 8rpx;
  align-self: flex-start;
}

.rate-badge.excellent {
  background: #dcfce7;
  color: #166534;
}

.rate-badge.good {
  background: #fef3c7;
  color: #92400e;
}

.rate-badge.fair {
  background: #fee2e2;
  color: #991b1b;
}

.rank-pill {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #fff8ec 0%, #fef3c7 100%);
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(249, 115, 22, 0.1);
}

.rank-icon-wrap {
  width: 48rpx;
  height: 48rpx;
  background: #ffffff;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  box-shadow: 0 4rpx 8rpx rgba(249, 115, 22, 0.15);
}

.rank-icon-wrap image {
  width: 28rpx;
  height: 28rpx;
}

.rank-val {
  font-size: 20rpx;
  font-weight: 800;
  color: #c2410c;
}

.hero-divider {
  height: 2rpx;
  background: linear-gradient(90deg, transparent 0%, #e2e8f0 50%, transparent 100%);
  margin: 32rpx 0 28rpx;
}

.hero-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24rpx;
  position: relative;
  z-index: 1;
}

.grid-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.ic {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 900;
  margin-bottom: 12rpx;
  position: relative;
}

.ic .ic-bg {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  opacity: 0.1;
}

.ic .ic-symbol {
  position: relative;
  z-index: 1;
}

.ic-green {
  background: linear-gradient(135deg, #dcfce7 0%, #bbf7d0 100%);
  color: #166534;
}

.ic-green .ic-bg {
  background: #166534;
}

.ic-orange {
  background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
  color: #92400e;
}

.ic-orange .ic-bg {
  background: #92400e;
}

.ic-red {
  background: linear-gradient(135deg, #fee2e2 0%, #fecaca 100%);
  color: #991b1b;
}

.ic-red .ic-bg {
  background: #991b1b;
}

.v {
  font-size: 48rpx;
  font-weight: 950;
  color: #1e293b;
  line-height: 1;
}

.l {
  font-size: 18rpx;
  color: #94a3b8;
  font-weight: 700;
  margin-top: 6rpx;
}

/* Sections */
.section-box {
  background: linear-gradient(135deg, #ffffff 0%, #fafbfc 100%);
  border-radius: 40rpx;
  padding: 40rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
}

.section-title {
  display: flex;
  align-items: baseline;
  margin-bottom: 36rpx;
}

.t-zh {
  font-size: 32rpx;
  font-weight: 800;
  color: #1e293b;
  margin-right: 12rpx;
  letter-spacing: 0.5rpx;
}

.t-en {
  font-size: 18rpx;
  color: #cbd5e1;
  font-weight: 700;
  letter-spacing: 2rpx;
  margin-left: 4rpx;
}

.t-count, .t-more {
  margin-left: auto;
  font-size: 22rpx;
  font-weight: 800;
  color: #10b981;
  padding: 6rpx 16rpx;
  background: #dcfce7;
  border-radius: 12rpx;
}

.t-more {
  background: #f1f5f9;
  color: #64748b;
}

/* Trend Bars */
.bar-grid {
  height: 240rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  padding: 0 16rpx 24rpx;
  border-bottom: 2rpx solid #e2e8f0;
  position: relative;
}

.bar-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.bar-track {
  width: 24rpx;
  height: 180rpx;
  background: #f8fafc;
  border-radius: 12rpx;
  position: relative;
  overflow: hidden;
  margin: 0 auto 16rpx;
  box-shadow: inset 0 2rpx 4rpx rgba(0, 0, 0, 0.03);
}

.bar-fill {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  border-radius: 12rpx;
  transition: height 0.8s cubic-bezier(0.4, 0, 0.2, 1);
}

.bar-fill.full {
  background: linear-gradient(180deg, #10b981 0%, #059669 100%);
  box-shadow: 0 0 12rpx rgba(16, 185, 129, 0.3);
}

.bar-fill.partial {
  background: linear-gradient(180deg, #f59e0b 0%, #d97706 100%);
  box-shadow: 0 0 12rpx rgba(245, 158, 11, 0.3);
}

.bar-fill.absent {
  background: linear-gradient(180deg, #ef4444 0%, #dc2626 100%);
  box-shadow: 0 0 12rpx rgba(239, 68, 68, 0.3);
}

.bar-fill.none {
  background: #e2e8f0;
}

.bar-label {
  font-size: 18rpx;
  color: #94a3b8;
  font-weight: 800;
  text-align: center;
}

.trend-legends {
  display: flex;
  justify-content: center;
  gap: 40rpx;
  margin-top: 28rpx;
  padding: 20rpx;
  background: #f8fafc;
  border-radius: 20rpx;
}

.leg { display: flex; align-items: center; }
.d { width: 14rpx; height: 14rpx; border-radius: 50%; margin-right: 12rpx; }
.d-full { background: linear-gradient(135deg, #10b981 0%, #059669 100%); }
.d-part { background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%); }
.d-none { background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%); }
.leg text { font-size: 20rpx; color: #64748b; font-weight: 700; }

/* Slots */
.slots-container { display: flex; flex-direction: column; gap: 24rpx; }
.slot-card { background: #f8fafc; padding: 28rpx; border-radius: 20rpx; }
.slot-meta-row { display: flex; justify-content: space-between; margin-bottom: 12rpx; }
.sn { font-size: 28rpx; font-weight: 700; color: #334155; }
.st { font-size: 20rpx; color: #94a3b8; font-weight: 700; }
.slot-bar-row { display: flex; align-items: center; gap: 16rpx; }
.p-track { flex: 1; height: 10rpx; background: #e2e8f0; border-radius: 5rpx; }
.p-fill { height: 100%; border-radius: 5rpx; transition: width 0.6s ease; }
.f-green { background: #10b981; }
.f-orange { background: #f59e0b; }
.f-red { background: #ef4444; }
.p-num { font-size: 24rpx; font-weight: 800; color: #475569; min-width: 60rpx; text-align: right; }

/* Medals */
.medal-wrap { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24rpx; }
.medal-node { display: flex; flex-direction: column; align-items: center; opacity: 0.3; filter: grayscale(1); }
.medal-node.is-active { opacity: 1; filter: grayscale(0); }
.medal-icon-box { width: 110rpx; height: 110rpx; background: #f1f5f9; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-bottom: 12rpx; position: relative; }
.medal-emoji { font-size: 48rpx; }
.medal-lock { position: absolute; top: 0; right: 0; font-size: 20rpx; }
.medal-label { font-size: 18rpx; color: #64748b; font-weight: 700; width: 100%; text-align: center; }

/* History */
.history-list { display: flex; flex-direction: column; gap: 20rpx; }
.history-card {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #f8fafc 0%, #ffffff 100%);
  padding: 24rpx;
  border-radius: 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  transition: transform 0.2s ease;
}
.h-side { margin-right: 24rpx; flex-shrink: 0; }
.h-date-box {
  width: 104rpx;
  height: 104rpx;
  background: linear-gradient(135deg, #ffffff 0%, #f8fafc 100%);
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.9);
}
.h-dd { font-size: 36rpx; font-weight: 900; color: #1e293b; }
.h-mm { font-size: 18rpx; color: #94a3b8; font-weight: 700; margin-top: 2rpx; }
.h-main { flex: 1; display: flex; flex-direction: column; }
.h-row1 { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12rpx; }
.h-date-full { font-size: 26rpx; font-weight: 800; color: #334155; }
.h-tag { font-size: 20rpx; padding: 6rpx 16rpx; border-radius: 10rpx; font-weight: 800; }
.h-tag.normal { background: linear-gradient(135deg, #dcfce7 0%, #bbf7d0 100%); color: #166534; }
.h-tag.late { background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%); color: #92400e; }
.h-tag.absent { background: linear-gradient(135deg, #fee2e2 0%, #fecaca 100%); color: #991b1b; }
.h-row2 { display: flex; gap: 28rpx; }
.h-inf { display: flex; align-items: center; }
.h-ic { width: 22rpx; height: 22rpx; margin-right: 8rpx; opacity: 0.4; }
.h-inf text { font-size: 22rpx; color: #94a3b8; font-weight: 700; }

.page-footer { padding: 60rpx 0 80rpx; display: flex; flex-direction: column; align-items: center; }
.page-footer text { font-size: 22rpx; color: #cbd5e1; font-weight: 700; }
.sys-info { font-size: 18rpx; color: #e2e8f0; margin-top: 8rpx; text-transform: uppercase; }

/* 3. Footer (Fixed Height, Non-scrollable) */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 -1rpx 0 #F1F5F9;
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 100;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  flex: 1;
}

.tab-icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
}

.tab-icon-img {
  width: 38rpx;
  height: 30rpx;
}

.tab-text {
  font-size: 20rpx;
  font-family: Inter, sans-serif;
  font-weight: 900;
  color: #90A1B9;
}

.tab-text-active {
  color: #009966;
}

.tab-active {
  position: relative;
}

.tab-active-bg {
  position: absolute;
  top: -48rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 120rpx;
  height: 120rpx;
  z-index: -1;
}

.safe-area-bottom {
  height: env(safe-area-inset-bottom);
}

/* Utilities */
.text-ellipsis {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}