<view class="app-root">
  <!-- 1. Header Area (Non-scrollable) -->
  <view class="app-header-light">
    <view class="status-bar-filler"></view>
    <view class="header-main">
      <view class="title-group">
        <view class="title-row">
          <view class="title-dot"></view>
          <text class="title-primary">数据报表</text>
        </view>
        <text class="title-secondary">{{currentDate}}</text>
      </view>
      <view class="sync-indicator">
        <view class="pulse-dot"></view>
        <text>实时同步</text>
      </view>
    </view>
    
    <view class="tab-scroller">
      <view class="tab-nav-light">
        <view class="tab-item {{selectedTab === 'week' ? 'active' : ''}}" bindtap="onTabSwitch" data-tab="week">本周</view>
        <view class="tab-item {{selectedTab === 'month' ? 'active' : ''}}" bindtap="onTabSwitch" data-tab="month">本月</view>
        <view class="tab-item {{selectedTab === 'semester' ? 'active' : ''}}" bindtap="onTabSwitch" data-tab="semester">学期</view>
        <view class="tab-active-bg-light" style="left: {{selectedTab === 'week' ? '0' : (selectedTab === 'month' ? '33.3%' : '66.6%')}}"></view>
      </view>
    </view>
  </view>

  <!-- 2. Body Area (Scrollable) -->
  <scroll-view class="app-body" scroll-y enable-back-to-top enhanced show-scrollbar="{{false}}">
    <view class="body-content">
      <!-- Hero Card -->
      <view class="hero-card">
        <view class="hero-top">
          <view class="rate-box">
            <text class="label">当前考勤率</text>
            <view class="num-row">
              <text class="big-val">{{attendanceRate}}</text>
              <text class="unit">%</text>
            </view>
            <view class="rate-badge {{attendanceRate >= 90 ? 'excellent' : (attendanceRate >= 80 ? 'good' : 'fair')}}">
              {{attendanceRate >= 90 ? '优秀' : (attendanceRate >= 80 ? '良好' : '需关注')}}
            </view>
          </view>
          <view class="rank-pill">
            <view class="rank-icon-wrap">
              <image src="/assets/CodeBubbyAssets/3_4/11.svg" mode="aspectFit"></image>
            </view>
            <text class="rank-val">排名 #{{schoolRank}}</text>
          </view>
        </view>

        <view class="hero-divider"></view>

        <view class="hero-grid">
          <view class="grid-item">
            <view class="ic ic-green">
              <text class="ic-bg"></text>
              <text class="ic-symbol">✓</text>
            </view>
            <text class="v">{{signedCount}}</text>
            <text class="l">正常</text>
          </view>
          <view class="grid-item">
            <view class="ic ic-orange">
              <text class="ic-bg"></text>
              <text class="ic-symbol">!</text>
            </view>
            <text class="v">{{lateCount}}</text>
            <text class="l">迟到</text>
          </view>
          <view class="grid-item">
            <view class="ic ic-red">
              <text class="ic-bg"></text>
              <text class="ic-symbol">?</text>
            </view>
            <text class="v">{{absentCount}}</text>
            <text class="l">缺勤</text>
          </view>
        </view>
      </view>

      <!-- Trends -->
      <view class="section-box">
        <view class="section-title">
          <text class="t-zh">签到趋势</text>
          <text class="t-en">ATTENDANCE TRENDS</text>
        </view>
        <view class="trend-container">
          <view class="bar-grid">
            <view wx:for="{{trendDays}}" wx:key="date" class="bar-col">
              <view class="bar-track">
                <view class="bar-fill {{item.status}}" style="height: {{item.status === 'none' ? '0' : (item.signed_count / item.total_slots * 100)}}%"></view>
              </view>
              <text class="bar-label">{{item.day_label}}</text>
            </view>
          </view>
          <view class="trend-legends">
            <view class="leg"><view class="d d-full"></view><text>全勤</text></view>
            <view class="leg"><view class="d d-part"></view><text>缺卡</text></view>
            <view class="leg"><view class="d d-none"></view><text>无记录</text></view>
          </view>
        </view>
      </view>

      <!-- Time Slots -->
      <view class="section-box">
        <view class="section-title">
          <text class="t-zh">分段统计</text>
          <text class="t-en">TIME SLOT STATS</text>
        </view>
        <view class="slots-container">
          <view wx:for="{{timeslotStats}}" wx:key="label" class="slot-card">
            <view class="slot-meta-row">
              <text class="sn">{{item.label}}</text>
              <text class="st">{{item.time_range}}</text>
            </view>
            <view class="slot-bar-row">
              <view class="p-track">
                <view class="p-fill {{item.rate >= 90 ? 'f-green' : (item.rate >= 80 ? 'f-orange' : 'f-red')}}" style="width: {{item.rate}}%"></view>
              </view>
              <text class="p-num">{{item.signed_count}}/{{item.total_count}}</text>
            </view>
          </view>
        </view>
      </view>

      <!-- Achievements -->
      <view class="section-box" wx:if="{{items.length > 0}}">
        <view class="section-title">
          <text class="t-zh">考勤勋章</text>
          <text class="t-en">ACHIEVEMENTS</text>
          <text class="t-count">{{unlocked_count}}/{{total_count}}</text>
        </view>
        <view class="medal-wrap">
          <view wx:for="{{items}}" wx:key="id" class="medal-node {{item.unlocked ? 'is-active' : ''}}">
            <view class="medal-icon-box">
              <text class="medal-emoji">{{item.emoji}}</text>
              <view class="medal-lock" wx:if="{{!item.unlocked}}">🔒</view>
            </view>
            <text class="medal-label text-ellipsis">{{item.name}}</text>
          </view>
        </view>
      </view>

      <!-- History -->
      <view class="section-box">
        <view class="section-title">
          <text class="t-zh">考勤流水</text>
          <text class="t-en">RECENT HISTORY</text>
          <text class="t-more" bindtap="viewAllRecords">查看详情 ></text>
        </view>
        <view class="history-list">
          <view wx:for="{{recentRecords}}" wx:key="date" class="history-card">
            <view class="h-side">
              <view class="h-date-box {{item.status}}">
                <text class="h-dd">{{item.day}}</text>
                <text class="h-mm">{{item.month}}</text>
              </view>
            </view>
            <view class="h-main">
              <view class="h-row1">
                <text class="h-date-full">{{item.date}}</text>
                <text class="h-tag {{item.status}}">{{item.status === 'normal' ? '正常' : (item.status === 'late' ? '迟到' : '缺勤')}}</text>
              </view>
              <view class="h-row2">
                <view class="h-inf" wx:if="{{item.first_checkin_time}}">
                  <image src="/assets/CodeBubbyAssets/3_4/36.svg" class="h-ic"></image>
                  <text>{{item.first_checkin_time}}</text>
                </view>
                <view class="h-inf">
                  <image src="/assets/CodeBubbyAssets/3_4/37.svg" class="h-ic"></image>
                  <text>{{item.location || '清涧中学'}}</text>
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>

      <view class="page-footer">
        <text>清涧中学版权所有 © 2026</text>
        <text class="sys-info">Digital Management Platform v2.2</text>
      </view>
    </view>
  </scroll-view>

  <!-- 3. Footer Area (Non-scrollable) -->
  <view class="tab-bar">
    <view class="tab-item" bindtap="switchTab" data-page="index">
      <view class="tab-icon">
        <image class="tab-icon-img" src="/assets/CodeBubbyAssets/5_4/1.svg" mode="aspectFit"></image>
      </view>
      <text class="tab-text">签到打卡</text>
    </view>
    <view class="tab-item tab-active" bindtap="switchTab" data-page="statistics">
      <image class="tab-active-bg" src="/assets/CodeBubbyAssets/5_4/4.svg" mode="aspectFit"></image>
      <view class="tab-icon">
        <image class="tab-icon-img" src="/assets/CodeBubbyAssets/5_4/2.svg" mode="aspectFit"></image>
      </view>
      <text class="tab-text tab-text-active">统计报表</text>
    </view>
    <view class="tab-item" bindtap="switchTab" data-page="profile">
      <view class="tab-icon">
        <image class="tab-icon-img" src="/assets/CodeBubbyAssets/5_4/3.svg" mode="aspectFit"></image>
      </view>
      <text class="tab-text">个人中心</text>
    </view>
  </view>
</view>