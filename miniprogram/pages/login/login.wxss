/* 全局容器 */
.login-container {
  height: 100vh;
  width: 100vw;
  background-color: #F8FAFC;
  position: relative;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

/* 背景光影装饰 */
.bg-decoration {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
  overflow: hidden;
  pointer-events: none;
}

.bg-circle {
  position: absolute;
  border-radius: 50%;
  filter: blur(80rpx);
  opacity: 0.6;
}

.bg-1 {
  width: 600rpx;
  height: 600rpx;
  top: -200rpx;
  right: -100rpx;
  background: linear-gradient(135deg, rgba(0, 188, 125, 0.3) 0%, rgba(0, 212, 146, 0.1) 100%);
}

.bg-2 {
  width: 500rpx;
  height: 500rpx;
  bottom: 0rpx;
  left: -150rpx;
  background: linear-gradient(135deg, rgba(236, 253, 245, 0.8) 0%, rgba(208, 250, 229, 0.4) 100%);
}

.bg-3 {
  width: 400rpx;
  height: 400rpx;
  top: 40%;
  right: -200rpx;
  background: linear-gradient(135deg, rgba(254, 243, 198, 0.4) 0%, rgba(255, 255, 255, 0) 100%);
}

/* 内容包装区 */
.content-wrapper {
  position: relative;
  z-index: 10;
  display: flex;
  flex-direction: column;
  flex: 1;
  padding: 0 40rpx;
  justify-content: center;
  align-items: center;
  margin-top: -160rpx; /* 在修改前-120rpx的基础上上移40rpx(即20px) */
}

/* 头部 Logo 区域 */
.header-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.logo-box {
  width: 140rpx;
  height: 140rpx;
  background: linear-gradient(135deg, #00BC7D 0%, #009689 100%);
  border-radius: 36rpx;
  padding: 10rpx;
  box-shadow: 0 16rpx 40rpx rgba(0, 188, 125, 0.25);
  margin-bottom: 24rpx;
  position: relative;
}

.logo-inner {
  width: 100%;
  height: 100%;
  background: #FFFFFF;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.logo-img {
  width: 72rpx;
  height: 72rpx;
}

.logo-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 32rpx;
  height: 32rpx;
  background: #FFB900;
  border: 4rpx solid #FFFFFF;
  border-radius: 50%;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.app-title {
  font-size: 40rpx;
  font-family: Inter, sans-serif;
  font-weight: 900;
  color: #1D293D;
  margin-bottom: 8rpx;
  letter-spacing: 2rpx;
}

.app-subtitle {
  font-size: 20rpx;
  font-family: Inter, sans-serif;
  font-weight: 700;
  color: #90A1B9;
  letter-spacing: 4rpx;
}

/* 登录卡片 */
.login-card {
  width: 100%;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  box-shadow: 0 25rpx 50rpx rgba(0, 0, 0, 0.05);
  border-radius: 48rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  padding: 48rpx 40rpx;
  box-sizing: border-box;
}

.login-heading {
  font-size: 40rpx;
  font-family: Inter, sans-serif;
  font-weight: 900;
  color: #0F172B;
  display: block;
  margin-bottom: 12rpx;
}

.login-subheading {
  font-size: 24rpx;
  font-family: Inter, sans-serif;
  font-weight: 500;
  color: #62748E;
  display: block;
  margin-bottom: 36rpx;
}

/* 表单输入框 */
.form-group {
  margin-bottom: 24rpx;
}

.input-wrapper {
  display: flex;
  align-items: center;
  height: 104rpx;
  background: #F8FAFC;
  border: 1rpx solid #E2E8F0;
  border-radius: 28rpx;
  padding: 0 24rpx;
  transition: all 0.3s ease;
}

.input-wrapper:active {
  background: #FFFFFF;
  border-color: #00BC7D;
  box-shadow: 0 0 0 4rpx rgba(0, 188, 125, 0.1);
}

.input-icon-box {
  width: 64rpx;
  height: 64rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.input-icon {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.8;
}

.global-input {
  flex: 1;
  height: 100%;
  font-size: 28rpx;
  font-family: Inter, sans-serif;
  font-weight: 700;
  color: #1D293D;
}

.input-placeholder {
  color: #90A1B9;
  font-weight: 500;
}

.forgot-pwd {
  display: flex;
  justify-content: flex-end;
  margin-bottom: 36rpx;
}

.forgot-text {
  font-size: 24rpx;
  font-family: Inter, sans-serif;
  font-weight: 700;
  color: #00BC7D;
}

/* 错误提示 */
.error-tip {
  background: #FFF5F5;
  border: 1rpx solid #FEB2B2;
  border-radius: 20rpx;
  padding: 16rpx 24rpx;
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
  animation: shake 0.4s ease-in-out;
}

.error-icon {
  width: 24rpx;
  height: 24rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.error-text {
  font-size: 22rpx;
  color: #C53030;
  font-weight: 600;
  line-height: 1.4;
}

@keyframes shake {
  0%, 100% { transform: translateX(0); }
  25% { transform: translateX(-8rpx); }
  75% { transform: translateX(8rpx); }
}

/* 按钮样式 */
.btn-container {
  width: 100%;
}

.login-btn {
  height: 112rpx;
  background: linear-gradient(135deg, #00BC7D 0%, #009689 100%);
  box-shadow: 0 16rpx 32rpx rgba(0, 188, 125, 0.25);
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.login-btn:active {
  transform: scale(0.98);
  box-shadow: 0 8rpx 16rpx rgba(0, 188, 125, 0.15);
}

.btn-text {
  font-size: 32rpx;
  font-family: Inter, sans-serif;
  font-weight: 900;
  color: #FFFFFF;
  letter-spacing: 4rpx;
}

.btn-arrow-box {
  position: absolute;
  right: 24rpx;
  width: 64rpx;
  height: 64rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-arrow {
  width: 32rpx;
  height: 32rpx;
  filter: brightness(0) invert(1);
}

/* 底部信息 */
.footer {
  position: absolute;
  bottom: 0;
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-bottom: 40rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  opacity: 0.5;
  z-index: 10;
}

.footer-icon {
  width: 64rpx;
  height: 4rpx;
  margin-bottom: 16rpx;
}

.footer-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.footer-title {
  font-size: 22rpx;
  font-family: Inter, sans-serif;
  font-weight: 900;
  color: #0F172B;
  margin-bottom: 8rpx;
}

.footer-record {
  font-size: 18rpx;
  font-family: Inter, sans-serif;
  font-weight: 700;
  color: #62748E;
  margin-bottom: 8rpx;
}

.footer-copyright {
  font-size: 18rpx;
  font-family: Inter, sans-serif;
  font-weight: 500;
  color: #90A1B9;
}
