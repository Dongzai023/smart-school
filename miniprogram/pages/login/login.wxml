<view class="login-container">
  <!-- 背景装饰 -->
  <view class="bg-decoration">
    <view class="bg-circle bg-1"></view>
    <view class="bg-circle bg-2"></view>
    <view class="bg-circle bg-3"></view>
  </view>

  <view class="content-wrapper">
    <!-- 头部 LOGO 和标题 -->
    <view class="header-section">
      <view class="logo-box">
        <view class="logo-inner">
          <image class="logo-img" src="/assets/CodeBubbyAssets/2_423/5.svg" mode="aspectFit"></image>
        </view>
        <view class="logo-badge"></view>
      </view>
      <text class="app-title">清涧中学考勤管理</text>
      <text class="app-subtitle">TEACHER ATTENDANCE SYSTEM</text>
    </view>

    <!-- 登录表单卡片 -->
    <view class="login-card">
      <text class="login-heading">教师登录</text>
      <text class="login-subheading">欢迎回来，请输入您的凭证</text>

      <view class="form-group">
        <view class="input-wrapper">
          <view class="input-icon-box">
            <image class="input-icon" src="/assets/CodeBubbyAssets/5_4/17.svg" mode="aspectFit"></image>
          </view>
          <input 
            class="global-input" 
            placeholder="请输入教工号 (如 QJ2023...)" 
            placeholder-class="input-placeholder"
            data-field="employeeId"
            bindinput="handleInput"
            value="{{employeeId}}"
          />
        </view>
      </view>

      <view class="form-group">
        <view class="input-wrapper">
          <view class="input-icon-box">
            <image class="input-icon" src="/assets/CodeBubbyAssets/5_4/19.svg" mode="aspectFit"></image>
          </view>
          <input 
            class="global-input" 
            password="true" 
            placeholder="请输入密码" 
            placeholder-class="input-placeholder"
            data-field="password"
            bindinput="handleInput"
            value="{{password}}"
          />
        </view>
      </view>

      <view class="forgot-pwd">
        <text class="forgot-text">忘记密码？</text>
      </view>

      <!-- 错误提示 -->
      <view class="error-tip" wx:if="{{errorMsg}}">
        <image class="error-icon" src="/assets/CodeBubbyAssets/2_509/1.svg" mode="aspectFit"></image>
        <text class="error-text">{{errorMsg}}</text>
      </view>

      <!-- 登录按钮 -->
      <view class="btn-container" bindtap="handleLogin">
        <view class="login-btn">
          <text class="btn-text">登 录</text>
          <view class="btn-arrow-box">
            <image class="btn-arrow" src="/assets/CodeBubbyAssets/5_4/18.svg" mode="aspectFit"></image>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部信息 -->
  <view class="footer">
    <image class="footer-icon" src="/assets/CodeBubbyAssets/2_509/1.svg" mode="aspectFit"></image>
    <view class="footer-content">
      <text class="footer-title">清涧中学 教师数字化管理平台</text>
      <text class="footer-record">陕ICP备202506048号</text>
      <text class="footer-copyright">版权所有 © 2024-2026 TD 数字科技。保留所有权利。</text>
    </view>
  </view>
</view>
