
<!-- 主内容区 -->
<view class="main-container">
  <!-- 头部 -->
  <view class="header">
  <!-- 实景展示 -->
  <view class="scene-card">
    <image class="scene-image" src="/assets/CodeBubbyAssets/2_517/qjmd.jpg" mode="aspectFill"></image>
    <view class="scene-overlay"></view>
    <view class="scene-content">
      <view class="camera-icon">
        <image class="camera-svg" src="/assets/CodeBubbyAssets/2_517/1.svg" mode="aspectFit"></image>
      </view>
      <view class="scene-text">
        <text class="scene-label">实景展示</text>
        <text class="scene-title">清涧中学 · 主教学区</text>
      </view>
    </view>
  </view>
  </view>

  <!-- 用户信息卡片 -->
  <view class="user-card">
    <view class="user-card-inner">
      <!-- 左侧头像 -->
      <view class="user-avatar-section">
        <view class="avatar-bg">
          <view class="avatar-white">
            <image class="avatar-icon" src="/assets/CodeBubbyAssets/2_423/5.svg" mode="aspectFit"></image>
          </view>
        </view>
        <view class="avatar-status-badge">
          <image class="status-icon" src="/assets/CodeBubbyAssets/2_423/6.svg" mode="aspectFit"></image>
        </view>
      </view>
      
      <!-- 中间信息 -->
      <view class="user-info-section">
        <view class="user-name-row">
          <text class="user-name-text">{{userInfo.name || '未登录'}}</text>
          <view class="user-badge" wx:if="{{userInfo.is_verified}}">
            <text class="badge-text">已认证教师</text>
          </view>
        </view>
        <view class="user-tags-row" wx:if="{{userInfo.nickname || userInfo.department}}">

          <view class="user-tag" wx:if="{{userInfo.nickname}}">
            <image class="tag-icon" src="/assets/CodeBubbyAssets/2_423/2.svg" mode="aspectFit"></image>
            <text class="tag-name">{{userInfo.nickname}}</text>
          </view>
          <view class="user-tag" wx:if="{{userInfo.department}}">
            <image class="tag-icon" src="/assets/CodeBubbyAssets/2_423/1.svg" mode="aspectFit"></image>
            <text class="tag-name">{{userInfo.department}}</text>
          </view>

        </view>
      </view>
      
      <!-- 右侧排名 -->
      <view class="user-rank-section">
        <image class="rank-divider" src="/assets/CodeBubbyAssets/2_423/3.svg" mode="aspectFit"></image>
        <view class="rank-content">
          <text class="rank-label-text">今日排名</text>
          <view class="rank-value">
            <text class="rank-number-text">{{userInfo.schoolRank || '--'}}</text>
            <image class="rank-trend-icon" src="/assets/CodeBubbyAssets/2_423/4.svg" mode="aspectFit"></image>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 签到安排 -->
  <view class="schedule-section">
    <view class="section-header">
      <view class="section-title-wrap">
        <view class="title-dot"></view>
        <text class="section-title">今日签到安排</text>
      </view>
      <view class="auto-update">
        <view class="refresh-icon"></view>
        <text class="update-text">自动更新</text>
      </view>
    </view>
    <view class="schedule-list">
      <view wx:for="{{todaySchedule}}" wx:key="index" class="schedule-item item-{{item.status}}">
        <text class="schedule-time">{{item.time_slot.start_time}}-{{item.time_slot.end_time}}</text>
        <text class="schedule-status status-{{item.status}}">{{item.status === 'signed' ? '已签' : (item.status === 'late' ? '迟到' : (item.status === 'unsigned' ? '未签' : '待签'))}}</text>
      </view>
    </view>
  </view>


  <!-- 打卡区域 -->
  <view class="checkin-section">
    <view class="checkin-bg"></view>
    <view class="time-badge">
      <view class="time-icon">
        <view class="clock-hand"></view>
      </view>
      <text class="time-label">{{timeLabel || '未知时段'}}</text>
    </view>
    <view class="checkin-time">
      <text class="current-time">{{currentTime}}</text>
      <view class="time-indicator"></view>
    </view>
    <view class="date-info">
      <view class="date-line"></view>
      <text class="current-date">{{currentDate}}</text>
      <view class="date-line"></view>
    </view>
  </view>

  <!-- 打卡按钮 -->
  <view class="checkin-btn-wrap">
    <view class="pulse-ring ring-1"></view>
    <view class="pulse-ring ring-2"></view>
    <view class="checkin-btn" bindtap="onCheckIn" hover-class="checkin-btn-active" hover-stay-time="100">
      <view class="btn-outer">
        <view class="btn-inner">
          <view class="btn-content">
            <text class="btn-text">签到</text>
            <view class="btn-line"></view>
            <text class="btn-subtext">立即打卡</text>
          </view>
        </view>
      </view>
    </view>
    <view class="checkin-hint">
      <view class="hint-dot"></view>
      <text class="hint-text">点击记录打卡</text>
    </view>
  </view>
</view>

  <!-- 考勤数据统计 -->
  <view class="stats-card" bindtap="switchTab" data-page="statistics">
    <view class="stats-icon-wrap">
      <view class="stats-icon">
        <view class="chart-bar"></view>
        <view class="chart-bar chart-bar-2"></view>
        <view class="chart-bar chart-bar-3"></view>
      </view>
    </view>
    <view class="stats-info">
      <text class="stats-title">考勤数据统计</text>
      <text class="stats-subtitle">DATA ANALYSIS CENTER</text>
    </view>
    <view class="arrow-icon">
      <view class="arrow-line"></view>
    </view>
  </view>

<!-- 底部信息 -->
<view class="footer">
  <image class="footer-icon" src="/assets/CodeBubbyAssets/2_509/1.svg" mode="aspectFit"></image>
  <view class="footer-content">
    <text class="footer-title">清涧中学 教师数字化管理平台</text>
    <text class="footer-record">陕ICP备202506048号</text>
    <text class="footer-copyright">版权所有 © 2024-2026 TD 数字科技。保留所有权利。</text>
  </view>
</view>

<!-- 底部导航 -->
<view class="tab-bar">
  <view class="tab-item tab-active" bindtap="switchTab" data-page="index">
    <image class="tab-active-bg" src="/assets/CodeBubbyAssets/5_4/4.svg" mode="aspectFit"></image>
    <view class="tab-icon">
      <image class="tab-icon-img" src="/assets/CodeBubbyAssets/5_4/1.svg" mode="aspectFit"></image>
    </view>
    <text class="tab-text tab-text-active">签到打卡</text>
  </view>
  <view class="tab-item" bindtap="switchTab" data-page="statistics">
    <view class="tab-icon">
      <image class="tab-icon-img" src="/assets/CodeBubbyAssets/5_4/2.svg" mode="aspectFit"></image>
    </view>
    <text class="tab-text">统计报表</text>
  </view>
  <view class="tab-item" bindtap="switchTab" data-page="profile">
    <view class="tab-icon">
      <image class="tab-icon-img" src="/assets/CodeBubbyAssets/5_4/3.svg" mode="aspectFit"></image>
    </view>
    <text class="tab-text">个人中心</text>
  </view>
</view>