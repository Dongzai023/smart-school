/* 主内容区 */
.main-container {
  padding: 0 32rpx 40rpx;
}

/* 头部 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0 0;
  margin-bottom: 16rpx;
}

.brand-title {
  font-size: 28rpx;
  font-weight: 900;
  color: #0F172B;
  display: block;
}

.brand-subtitle {
  font-size: 16rpx;
  font-weight: 700;
  color: #90A1B9;
  display: block;
}

.settings-btn {
  width: 54rpx;
  height: 54rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(226, 232, 240, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.settings-icon {
  display: flex;
  align-items: center;
}

.settings-dot {
  width: 6rpx;
  height: 6rpx;
  background: #0F172B;
  border-radius: 50%;
  margin-right: 6rpx;
}

.settings-dot:last-child {
  margin-right: 0;
}

.settings-line {
  width: 4rpx;
  height: 16rpx;
  background: #0F172B;
}

/* 用户信息卡片 */
.user-card {
  background: rgba(255, 255, 255, 0.8);
  border: 1rpx solid rgba(255, 255, 255, 0.4);
  border-radius: 32rpx;
  padding: 0 24rpx 24rpx 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 60rpx rgba(0, 0, 0, 0.04);
  box-sizing: border-box;
}

.user-card-inner {
  display: flex;
  align-items: center;
  height: 128rpx;
}

/* 左侧头像 */
.user-avatar-section {
  position: relative;
  width: 128rpx;
  height: 128rpx;
  margin-right: 32rpx;
  flex-shrink: 0;
}

.avatar-bg {
  width: 128rpx;
  height: 128rpx;
  background: linear-gradient(135deg, #00BC7D 0%, #009689 100%);
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.1);
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-white {
  width: 120rpx;
  height: 120rpx;
  background: #FFFFFF;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.avatar-icon {
  width: 64rpx;
  height: 64rpx;
}

.avatar-status-badge {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 44rpx;
  height: 44rpx;
  background: #FFB900;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  border-radius: 50%;
  border: 4rpx solid #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
}

.status-icon {
  width: 24rpx;
  height: 24rpx;
}

/* 中间信息 */
.user-info-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.user-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.user-name-text {
  font-size: 36rpx;
  font-family: Inter, sans-serif;
  font-weight: 900;
  color: #1D293D;
  margin-right: 16rpx;
}

.user-badge {
  background: #ECFDF5;
  border: 1rpx solid #D0FAE5;
  border-radius: 100rpx;
  padding: 4rpx 16rpx;
}

.badge-text {
  font-size: 20rpx;
  font-family: Inter, sans-serif;
  font-weight: 700;
  color: #009966;
}

.user-tags-row {
  display: flex;
  flex-direction: row;
}

.user-tag {
  display: flex;
  align-items: center;
  margin-right: 24rpx;
}

.user-tag:last-child {
  margin-right: 0;
}

.tag-icon {
  width: 16rpx;
  height: 16rpx;
  margin-right: 8rpx;
}

.tag-name {
  font-size: 24rpx;
  font-family: Inter, sans-serif;
  font-weight: 500;
  color: #90A1B9;
}

/* 右侧排名 */
.user-rank-section {
  display: flex;
  align-items: center;
  flex-shrink: 0;
}

.rank-divider {
  width: 2rpx;
  height: 80rpx;
  margin-right: 16rpx;
}

.rank-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.rank-label-text {
  font-size: 20rpx;
  font-family: Inter, sans-serif;
  font-weight: 900;
  color: #FE9A00;
  margin-bottom: 8rpx;
}

.rank-value {
  display: flex;
  align-items: center;
}

.rank-number-text {
  font-size: 40rpx;
  font-family: Inter, sans-serif;
  font-weight: 900;
  color: #1D293D;
  margin-right: 8rpx;
}

.rank-trend-icon {
  width: 24rpx;
  height: 24rpx;
}

/* 签到安排 */
.schedule-section {
  margin-bottom: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title-wrap {
  display: flex;
  align-items: center;
}

.title-dot {
  width: 8rpx;
  height: 32rpx;
  background: #00BC7D;
  border-radius: 4rpx;
  margin-right: 16rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 900;
  color: #1D293D;
}

.auto-update {
  display: flex;
  align-items: center;
  background: #F1F5F9;
  border-radius: 16rpx;
  padding: 8rpx 16rpx;
}

.refresh-icon {
  width: 20rpx;
  height: 20rpx;
  border: 2rpx solid #90A1B9;
  border-radius: 50%;
  border-right-color: transparent;
  margin-right: 8rpx;
}

.update-text {
  font-size: 20rpx;
  font-weight: 700;
  color: #90A1B9;
}

.schedule-list {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
}

.schedule-item {
  flex: 1;
  height: 98rpx;
  border-radius: 28rpx;
  padding: 16rpx 8rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  box-sizing: border-box;
  margin-right: 8rpx;
  min-width: 140rpx;
}

.schedule-item:last-child {
  margin-right: 0;
}

.item-unsigned {
  background: rgba(255, 241, 242, 0.5);
  border: 1rpx solid #FFE4E6;
  box-shadow: 0 8rpx 24rpx rgba(244, 63, 94, 0.08);
}

.item-signed {
  background: rgba(236, 253, 245, 0.5);
  border: 1rpx solid #D0FAE5;
  box-shadow: 0 8rpx 24rpx rgba(16, 185, 129, 0.08);
}

.item-late {
  background: rgba(255, 245, 230, 0.5);
  border: 1rpx solid #FFE4B5;
  box-shadow: 0 8rpx 24rpx rgba(255, 165, 0, 0.08);
}

.item-pending {
  background: #FFFFFF;
  border: 1rpx solid #F1F5F9;
}

.schedule-time {
  font-size: 16rpx;
  font-weight: 700;
  color: #90A1B9;
  text-align: center;
}

.schedule-status {
  font-size: 24rpx;
  font-weight: 900;
  text-align: center;
}

.status-unsigned {
  color: #FF2056;
}

.status-signed {
  color: #009966;
}

.status-late {
  color: #FFA500;
}

.status-pending {
  color: #CAD5E2;
}

/* 考勤数据统计 */
.stats-card {
  background: #FFFFFF;
  border: 1rpx solid #F1F5F9;
  border-radius: 32rpx;
  padding: 24rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.05);
}

.stats-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  background: #ECFDF5;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.stats-icon {
  display: flex;
  align-items: flex-end;
  height: 40rpx;
}

.chart-bar {
  margin-right: 6rpx;
  width: 8rpx;
  background: #009966;
  border-radius: 4rpx;
  height: 20rpx;
}

.chart-bar:last-child {
  margin-right: 0;
}

.chart-bar-2 {
  height: 32rpx;
}

.chart-bar-3 {
  height: 24rpx;
}

.stats-info {
  flex: 1;
  margin-left: 24rpx;
}

.stats-title {
  font-size: 28rpx;
  font-weight: 900;
  color: #1D293D;
  display: block;
}

.stats-subtitle {
  font-size: 20rpx;
  font-weight: 700;
  color: #90A1B9;
}

.arrow-icon {
  width: 32rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.arrow-line {
  width: 10rpx;
  height: 10rpx;
  border-top: 4rpx solid #CAD5E2;
  border-right: 4rpx solid #CAD5E2;
  transform: rotate(45deg);
}

/* 实景展示 */
.scene-card {
  position: relative;
  width: 100%;
  height: 300rpx;
  border-radius: 32rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 25rpx 50rpx rgba(0, 0, 0, 0.08);
  background: rgba(255, 255, 255, 0);
}

.scene-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.scene-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(0deg, rgba(0, 0, 0, 0.6) 0%, rgba(0, 0, 0, 0) 50%, rgba(0, 0, 0, 0) 100%);
}

.scene-content {
  position: absolute;
  left: 32rpx;
  bottom: 20rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
}

.camera-icon {
  width: 48rpx;
  height: 48rpx;
  background: #00BC7D;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.1);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.camera-svg {
  width: 24rpx;
  height: 24rpx;
}

.scene-text {
  display: flex;
  flex-direction: column;
  height: 60rpx;
  justify-content: space-between;
}

.scene-label {
  font-size: 20rpx;
  font-family: Inter, sans-serif;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.8);
  line-height: 20rpx;
  height: 20rpx;
}

.scene-title {
  font-size: 28rpx;
  font-family: Inter, sans-serif;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 40rpx;
  height: 40rpx;
}

/* 打卡区域 */
.checkin-section {
  position: relative;
  height: 240rpx;
  border-radius: 64rpx;
  background: linear-gradient(135deg, #FFF7ED 0%, rgba(255, 241, 242, 0.4) 100%);
  border: 1rpx solid #FFFFFF;
  padding: 20rpx 32rpx 10rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 20rpx 50rpx rgba(0, 0, 0, 0.04);
  overflow: hidden;
}

.checkin-bg {
  position: absolute;
  top: -80rpx;
  right: -80rpx;
  width: 320rpx;
  height: 240rpx;
  background: rgba(255, 237, 212, 0.3);
  border-radius: 50%;
  filter: blur(60rpx);
}

.time-badge {
  position: absolute;
  top: 48rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.6);
  border: 1rpx solid rgba(255, 237, 212, 0.5);
  border-radius: 100rpx;
  padding: 12rpx 24rpx;
}

.time-icon {
  margin-right: 16rpx;
  width: 24rpx;
  height: 24rpx;
  position: relative;
}

.clock-hand {
  width: 100%;
  height: 100%;
  border: 2rpx solid #F54900;
  border-radius: 50%;
  position: relative;
}

.clock-hand::before,
.clock-hand::after {
  content: '';
  position: absolute;
  background: #F54900;
  left: 50%;
  transform: translateX(-50%);
}

.clock-hand::before {
  width: 2rpx;
  height: 8rpx;
  top: 4rpx;
}

.clock-hand::after {
  width: 2rpx;
  height: 6rpx;
  top: 50%;
  transform: translateX(-50%) rotate(90deg);
}

.time-label {
  font-size: 20rpx;
  font-weight: 900;
  color: #F54900;
}

.checkin-time {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 72rpx;
}

.current-time {
  margin-right: 16rpx;
  font-size: 72rpx;
  font-weight: 700;
  background: linear-gradient(180deg, #0F172B 0%, #314158 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.time-indicator {
  width: 12rpx;
  height: 12rpx;
  background: #00BC7D;
  opacity: 0.65;
  border-radius: 50%;
  margin-left: 16rpx;
}

.date-info {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 16rpx;
}

.date-line {
  width: 24rpx;
  height: 2rpx;
  background: #E2E8F0;
  margin: 0 20rpx;
}

.current-date {
  font-size: 22rpx;
  font-weight: 700;
  color: #62748E;
}

/* 打卡按钮 */
.checkin-btn-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  margin-bottom: 48rpx;
  height: 420rpx;
  justify-content: center;
  z-index: 9999;
}

.pulse-ring {
  position: absolute;
  border: 2rpx solid rgba(0, 188, 125, 0.1);
  border-radius: 50%;
  pointer-events: none;
}

.ring-1 {
  width: 540rpx;
  height: 540rpx;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  animation: ripple 3s ease-out infinite;
}

.ring-2 {
  width: 496rpx;
  height: 496rpx;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  border-color: rgba(0, 188, 125, 0.05);
  animation: ripple 3s ease-out infinite 1s;
}

.checkin-btn {
  width: 352rpx;
  height: 352rpx;
  background: linear-gradient(135deg, #00BC7D 0%, #00786F 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 15rpx 40rpx rgba(0, 188, 125, 0.2);
  position: relative;
  z-index: 1;
  transition: transform 0.15s ease;
}

.checkin-btn::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: inherit;
  border-radius: inherit;
  z-index: -1;
  animation: pulse 4s ease-in-out infinite;
  box-shadow: 0 0 0 rgba(0, 188, 125, 0);
  pointer-events: none;
}

.checkin-btn-active {
  transform: scale(0.96);
}

.checkin-btn-active::after {
  animation: none;
  box-shadow: 0 10rpx 20rpx rgba(0, 188, 125, 0.2);
}

.btn-outer {
  width: 316rpx;
  height: 316rpx;
  background: rgba(255, 255, 255, 0.2);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-inner {
  width: 268rpx;
  height: 268rpx;
  background: rgba(255, 255, 255, 0.1);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.btn-text {
  font-size: 60rpx;
  font-family: Inter, sans-serif;
  font-weight: 900;
  color: #FFFFFF;
  text-shadow: 0 6rpx 12rpx rgba(0, 0, 0, 0.12);
  margin-bottom: 12rpx;
}

.btn-line {
  width: 64rpx;
  height: 4rpx;
  background: rgba(0, 212, 146, 0.6);
  border-radius: 2rpx;
  margin-top: 12rpx;
  margin-bottom: 12rpx;
}

.btn-subtext {
  font-size: 18rpx;
  font-weight: 900;
  color: #D0FAE5;
}

.checkin-hint {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border: 1rpx solid #F1F5F9;
  border-radius: 100rpx;
  padding: 16rpx 32rpx;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.08);
  margin-top: 32rpx;
}

.hint-dot {
  width: 10rpx;
  height: 12rpx;
  background: #00BC7D;
  opacity: 0.65;
  border-radius: 50%;
  margin-right: 12rpx;
}

.hint-text {
  font-size: 20rpx;
  font-weight: 900;
  color: #1D293D;
}

/* 底部信息 */
.footer {
  position: relative;
  width: 100%;
  height: 300rpx;
  opacity: 0.4;
  padding-bottom: 200rpx;
}

.footer-icon {
  position: absolute;
  width: 64rpx;
  height: 4rpx;
  left: 50%;
  top: 80rpx;
  transform: translateX(-50%);
}

.footer-content {
  position: absolute;
  top: 114rpx;
  left: 0;
  right: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.footer-title {
  font-size: 24rpx;
  font-family: Inter, sans-serif;
  font-weight: 900;
  color: #0F172B;
  text-align: center;
  margin-bottom: 20rpx;
}

.footer-record {
  font-size: 20rpx;
  font-family: Inter, sans-serif;
  font-weight: 700;
  color: #62748E;
  text-align: center;
  margin-bottom: 16rpx;
}

.footer-copyright {
  font-size: 16rpx;
  font-family: Inter, sans-serif;
  font-weight: 500;
  color: #90A1B9;
  text-align: center;
}

/* 底部导航 */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 -1rpx 0 #F1F5F9;
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 100;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.tab-icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
}

.tab-icon-img {
  width: 38rpx;
  height: 30rpx;
}

.tab-text {
  font-size: 20rpx;
  font-family: Inter, sans-serif;
  font-weight: 900;
  color: #90A1B9;
}

.tab-text-active {
  color: #009966;
}

.tab-active {
  position: relative;
}

.tab-active-bg {
  position: absolute;
  top: -48rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 120rpx;
  height: 120rpx;
  z-index: -1;
}

/* 动画定义 */
@keyframes pulse {
  0% {
    box-shadow: 0 15rpx 30rpx rgba(0, 188, 125, 0.15);
    opacity: 0.8;
  }
  50% {
    box-shadow: 0 30rpx 70rpx rgba(0, 188, 125, 0.4);
    opacity: 1;
  }
  100% {
    box-shadow: 0 15rpx 30rpx rgba(0, 188, 125, 0.15);
    opacity: 0.8;
  }
}

@keyframes ripple {
  0% {
    transform: translate(-50%, -50%) scale(0.8);
    opacity: 0.5;
  }
  100% {
    transform: translate(-50%, -50%) scale(1.2);
    opacity: 0;
  }
}