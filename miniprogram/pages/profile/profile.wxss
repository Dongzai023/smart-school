/** 个人中心页面样式 **/
page {
  background: #F8FAFC;
  width: 100%;
  margin: 0;
  padding: 0;
}
.container {
  width:100%;
  position: relative;
  padding-bottom: 120rpx;
  margin-top: -198rpx;
}

/* 头部绿色背景区域 */
.header-bg {
  background: linear-gradient(135deg, #00BC7D 0%, #00BBA7 100%);
  padding: 0 32rpx 18rpx;
  width: 100%;
  box-sizing: border-box;
}

/* 用户信息 */
.user-section {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-area {
  display: flex;
  justify-content: center;
  margin-bottom: 32rpx;
  margin-top: 32rpx;
}

.avatar-wrap {
  position: relative;
  width: 192rpx;
  height: 192rpx;
}

.avatar-outer {
  width: 192rpx;
  height: 192rpx;
  background: #FFFFFF;
  box-shadow: 0 25rpx 50rpx -12rpx rgba(0, 79, 59, 0.2);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-inner {
  width: 176rpx;
  height: 176rpx;
  border-radius: 40rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-inner.has-avatar {
  background: transparent;
}

.avatar-img {
  width: 96rpx;
  height: 96rpx;
}

.avatar-full {
  width: 100%;
  height: 100%;
}

.edit-badge {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 64rpx;
  height: 64rpx;
  background: #00BC7D;
  box-shadow: 0 4rpx 6rpx -4rpx rgba(0, 0, 0, 0.1), 0 10rpx 15rpx -3rpx rgba(0, 0, 0, 0.1);
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #FFFFFF;
}

.edit-icon {
  width: 32rpx;
  height: 32rpx;
}

.user-name {
  font-size: 48rpx;
  font-family: Inter, sans-serif;
  font-weight: 900;
  color: #FFFFFF;
  margin-bottom: 16rpx;
  text-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.15);
  line-height: 1;
}

.user-tags {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 32rpx;
}

.user-tag-text {
  font-size: 28rpx;
  font-family: Inter, sans-serif;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.8);
}

.user-tag-dot {
  font-size: 32rpx;
  font-family: Inter, sans-serif;
  font-weight: 400;
  color: rgba(255, 255, 255, 0.6);
  margin: 0 12rpx;
}

.user-id-wrap {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  margin-top: 24rpx;
}

.user-id-badge {
  height: 74rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 100rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  padding: 0 36rpx;
  margin-right: 22rpx;
}

.user-id-text {
  font-size: 24rpx;
  font-family: Inter, sans-serif;
  font-weight: 700;
  color: #FFFFFF;
  white-space: nowrap;
}

.copy-btn {
  width: 64rpx;
  height: 64rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 100rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.copy-icon {
  width: 28rpx;
  height: 28rpx;
}

/* 统计信息卡片 */
.stats-card {
  display: flex;
  justify-content: space-around;
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 25rpx 50rpx -12rpx rgba(0, 0, 0, 0.25);
  border-radius: 48rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  padding: 22rpx 32rpx;
  margin-top: 40rpx;
  position: relative;
  z-index: 10;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-number {
  font-size: 48rpx;
  font-family: Inter, sans-serif;
  font-weight: 900;
  margin-bottom: 8rpx;
}

.stat-green {
  color: #009966;
}

.stat-orange {
  color: #E17100;
}

.stat-purple {
  color: #9810FA;
}

.stat-label {
  font-size: 20rpx;
  font-family: Inter, sans-serif;
  font-weight: 700;
  color: #62748E;
}

/* 主内容区 */
.main-content {
  background: #F8FAFC;
  padding: 60rpx 32rpx 40rpx;
}

/* 快捷功能入口 */
.quick-grid {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.quick-item {
  position: relative;
  flex: 1;
  height: 204rpx;
  background: #FFFFFF;
  box-shadow: 0 4rpx 6rpx -4rpx rgba(0, 0, 0, 0.1), 0 10rpx 15rpx -3rpx rgba(0, 0, 0, 0.1);
  border-radius: 32rpx;
  border: 1rpx solid rgba(226, 232, 240, 0.5);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  min-width: 140rpx;
}

.quick-item:last-child {
  margin-right: 0;
}

.quick-icon {
  width: 96rpx;
  height: 96rpx;
  box-shadow: 0 4rpx 6rpx -4rpx rgba(0, 0, 0, 0.1), 0 10rpx 15rpx -3rpx rgba(0, 0, 0, 0.1);
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.quick-green {
  background: linear-gradient(135deg, #00BC7D 0%, #00BBA7 100%);
}

.quick-blue {
  background: linear-gradient(135deg, #2B7FFF 0%, #00B8DB 100%);
}

.quick-orange {
  background: linear-gradient(135deg, #FE9A00 0%, #FF6900 100%);
}

.quick-gray {
  background: linear-gradient(135deg, #62748E 0%, #45556C 100%);
}

.quick-icon-img {
  width: 48rpx;
  height: 48rpx;
}

.quick-text {
  font-size: 20rpx;
  font-family: Inter, sans-serif;
  font-weight: 700;
  color: #314158;
  letter-spacing: 1rpx;
}

.quick-badge {
  position: absolute;
  top: -16rpx;
  right: -8rpx;
  min-width: 40rpx;
  height: 40rpx;
  background: #FF2056;
  box-shadow: 0 4rpx 6rpx -4rpx rgba(0, 0, 0, 0.1), 0 10rpx 15rpx -3rpx rgba(0, 0, 0, 0.1);
  border-radius: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 12rpx;
}

.badge-wide {
  min-width: 60rpx;
}

.quick-badge-text {
  font-size: 20rpx;
  font-family: Inter, sans-serif;
  font-weight: 900;
  color: #FFFFFF;
}

/* 区块样式 */
.section {
  margin-bottom: 32rpx;
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-icon {
  width: 24rpx;
  height: 24rpx;
  margin-right: 8rpx;
}

.section-title-wrap {
  display: flex;
  flex-direction: column;
}

.section-title {
  font-size: 32rpx;
  font-family: Inter, sans-serif;
  font-weight: 900;
  color: #0F172B;
  margin-bottom: 4rpx;
}

.section-subtitle {
  font-size: 20rpx;
  font-family: Inter, sans-serif;
  font-weight: 700;
  color: #90A1B9;
  letter-spacing: 2rpx;
}

/* 活动卡片 */
.activity-card {
  background: #FFFFFF;
  box-shadow: 0 4rpx 6rpx -4rpx rgba(0, 0, 0, 0.1), 0 10rpx 15rpx -3rpx rgba(0, 0, 0, 0.1);
  border-radius: 32rpx;
  border: 1rpx solid rgba(226, 232, 240, 0.5);
  overflow: hidden;
}

.activity-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #F1F5F9;
}

.activity-item:last-child {
  border-bottom: none;
}

.activity-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.activity-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.activity-title {
  font-size: 28rpx;
  font-family: Inter, sans-serif;
  font-weight: 700;
  color: #1D293D;
  margin-bottom: 8rpx;
}

.activity-time {
  font-size: 22rpx;
  font-family: Inter, sans-serif;
  font-weight: 500;
  color: #90A1B9;
}

.activity-arrow {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
}

/* 菜单卡片 */
.menu-card {
  background: #FFFFFF;
  box-shadow: 0 4rpx 6rpx -4rpx rgba(0, 0, 0, 0.1), 0 10rpx 15rpx -3rpx rgba(0, 0, 0, 0.1);
  border-radius: 32rpx;
  border: 1rpx solid rgba(226, 232, 240, 0.5);
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #F1F5F9;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  background: #F1F5F9;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.menu-icon {
  width: 40rpx;
  height: 40rpx;
}

.menu-text {
  font-size: 28rpx;
  font-family: Inter, sans-serif;
  font-weight: 700;
  color: #1D293D;
}

.menu-right {
  display: flex;
  align-items: center;
}

.menu-hint {
  font-size: 24rpx;
  font-family: Inter, sans-serif;
  font-weight: 500;
  color: #90A1B9;
  margin-right: 16rpx;
}

.menu-hint-long {
  max-width: 280rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.menu-arrow {
  width: 32rpx;
  height: 32rpx;
}

.theme-switch {
  transform: scale(0.8);
}

/* 退出登录按钮 */
.logout-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 112rpx;
  background: linear-gradient(90deg, #FF2056 0%, #EC003F 100%);
  box-shadow: 0 8rpx 10rpx -6rpx rgba(255, 32, 86, 0.3), 0 20rpx 25rpx -5rpx rgba(255, 32, 86, 0.3);
  border-radius: 32rpx;
  margin-bottom: 32rpx;
}

.logout-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
}

.logout-text {
  font-size: 32rpx;
  font-family: Inter, sans-serif;
  font-weight: 900;
  color: #FFFFFF;
}

/* 底部信息 */
.footer {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 0;
  opacity: 0.4;
}

.footer-icon {
  width: 64rpx;
  height: 4rpx;
  margin-bottom: 16rpx;
}

.footer-title {
  font-size: 20rpx;
  font-family: Inter, sans-serif;
  font-weight: 900;
  color: #0F172B;
  margin-bottom: 16rpx;
  letter-spacing: 2rpx;
}

.footer-subtitle {
  font-size: 18rpx;
  font-family: Inter, sans-serif;
  font-weight: 700;
  color: #62748E;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}

.footer-copyright {
  font-size: 18rpx;
  font-family: Inter, sans-serif;
  font-weight: 500;
  color: #90A1B9;
}

/* 底部导航 */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 -1rpx 0 #F1F5F9;
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 100;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.tab-icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
}

.tab-icon-img {
  width: 38rpx;
  height: 30rpx;
}

.tab-text {
  font-size: 20rpx;
  font-family: Inter, sans-serif;
  font-weight: 900;
  color: #90A1B9;
}

.tab-text-active {
  color: #009966;
}

.tab-active {
  position: relative;
}

.tab-active-bg {
  position: absolute;
  top: -48rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 120rpx;
  height: 120rpx;
  z-index: -1;
}

/* 编辑弹窗样式 */
.edit-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
}

.edit-modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.edit-modal-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
}

.edit-modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #E5E7EB;
}

.edit-modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1F2937;
}

.edit-modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.close-icon {
  width: 32rpx;
  height: 32rpx;
}

.edit-modal-body {
  padding: 32rpx;
  flex: 1;
  box-sizing: border-box;
}

.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 28rpx;
  color: #4B5563;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background: #F3F4F6;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.picker-view {
  width: 100%;
  height: 80rpx;
  background: #F3F4F6;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  box-sizing: border-box;
}

.placeholder-text {
  color: #9CA3AF;
}

.btn-group {
  display: flex;
  gap: 24rpx;
  margin-top: 32rpx;
  margin-bottom: 48rpx;
}

.cancel-btn,
.save-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cancel-btn {
  background: #F3F4F6;
  color: #4B5563;
  border: none;
}

.save-btn {
  background: linear-gradient(135deg, #00BC7D 0%, #00BBA7 100%);
  color: #FFFFFF;
  border: none;
}
