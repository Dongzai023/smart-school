<view class="container">
  <!-- 渐变背景 -->
  <view class="header-bg">
    <view class="bg-shape shape-1"></view>
    <view class="bg-shape shape-2"></view>
  </view>

  <!-- 顶部标题区 -->
  <view class="page-header">
    <view class="header-title">请假申请</view>
    <view class="header-subtitle">LEAVE APPLICATION</view>
  </view>

  <view class="tabs">
    <view class="tab-item {{currentTab === 'apply' ? 'active' : ''}}" bindtap="switchTab" data-tab="apply">
      <view class="tab-content">
        <text class="tab-text">我要请假</text>
        <view class="active-indicator"></view>
      </view>
    </view>
    <view class="tab-item {{currentTab === 'history' ? 'active' : ''}}" bindtap="switchTab" data-tab="history">
      <view class="tab-content">
        <text class="tab-text">我的申请</text>
        <view class="active-indicator"></view>
      </view>
    </view>
  </view>

  <!-- 申请表单 -->
  <view class="content-wrapper" wx:if="{{currentTab === 'apply'}}">
    <view class="card-box form-card">
      <view class="card-header">
        <view class="card-icon-wrap">
          <image class="card-icon" src="/assets/CodeBubbyAssets/5_4/14.svg" mode="aspectFit"></image>
        </view>
        <text class="card-title">填写请假信息</text>
      </view>
      
      <form bindsubmit="submitForm">
        <view class="form-section">
          <!-- 请假类型 -->
          <view class="form-group">
            <view class="form-label">
              <text class="label-text">请假类型</text>
              <text class="required-star">*</text>
            </view>
            <picker mode="selector" range="{{leaveTypes}}" value="{{typeIndex}}" bindchange="onTypeChange">
              <view class="picker-view {{typeIndex >= 0 ? 'has-value' : ''}}">
                <text class="picker-text">{{typeIndex >= 0 ? leaveTypes[typeIndex] : '请选择请假类型'}}</text>
                <image class="picker-arrow" src="/assets/CodeBubbyAssets/5_4/11.svg" mode="aspectFit"></image>
              </view>
            </picker>
          </view>

          <!-- 开始时间 -->
          <view class="form-group">
            <view class="form-label">
              <text class="label-text">开始时间</text>
              <text class="required-star">*</text>
            </view>
            <view class="datetime-group">
              <picker mode="date" value="{{startDate}}" bindchange="onStartDateChange" class="datetime-picker">
                <view class="picker-view {{startDate ? 'has-value' : ''}}">
                  <text class="picker-text">{{startDate || '选择日期'}}</text>
                  <image class="picker-arrow" src="/assets/CodeBubbyAssets/5_4/11.svg" mode="aspectFit"></image>
                </view>
              </picker>
              <picker mode="time" value="{{startTime}}" bindchange="onStartTimeChange" class="datetime-picker">
                <view class="picker-view {{startTime ? 'has-value' : ''}}">
                  <text class="picker-text">{{startTime || '选择时间'}}</text>
                  <image class="picker-arrow" src="/assets/CodeBubbyAssets/5_4/11.svg" mode="aspectFit"></image>
                </view>
              </picker>
            </view>
          </view>

          <!-- 结束时间 -->
          <view class="form-group">
            <view class="form-label">
              <text class="label-text">结束时间</text>
              <text class="required-star">*</text>
            </view>
            <view class="datetime-group">
              <picker mode="date" value="{{endDate}}" bindchange="onEndDateChange" class="datetime-picker">
                <view class="picker-view {{endDate ? 'has-value' : ''}}">
                  <text class="picker-text">{{endDate || '选择日期'}}</text>
                  <image class="picker-arrow" src="/assets/CodeBubbyAssets/5_4/11.svg" mode="aspectFit"></image>
                </view>
              </picker>
              <picker mode="time" value="{{endTime}}" bindchange="onEndTimeChange" class="datetime-picker">
                <view class="picker-view {{endTime ? 'has-value' : ''}}">
                  <text class="picker-text">{{endTime || '选择时间'}}</text>
                  <image class="picker-arrow" src="/assets/CodeBubbyAssets/5_4/11.svg" mode="aspectFit"></image>
                </view>
              </picker>
            </view>
          </view>
          
          <!-- 请假事由 -->
          <view class="form-group">
            <view class="form-label">
              <text class="label-text">请假事由</text>
              <text class="required-star">*</text>
            </view>
            <view class="textarea-wrap">
              <textarea class="form-textarea" name="reason" value="{{reason}}" placeholder="请详细描述请假原因..." placeholder-class="textarea-placeholder" maxlength="500"></textarea>
              <view class="word-count">{{reason.length || 0}}/500</view>
            </view>
          </view>
        </view>

        <view class="submit-wrap">
          <button class="submit-btn" form-type="submit" loading="{{isSaving}}">
            <text wx:if="{{!isSaving}}">提交申请</text>
          </button>
        </view>
      </form>
    </view>
  </view>

  <!-- 历史记录 -->
  <view class="content-wrapper" wx:if="{{currentTab === 'history'}}">
    <view class="empty-state" wx:if="{{historyList.length === 0}}">
      <view class="empty-icon-wrap">
        <image class="empty-icon" src="/assets/CodeBubbyAssets/5_4/40.svg" mode="aspectFit"></image>
      </view>
      <text class="empty-text">暂无请假申请记录</text>
      <text class="empty-subtext">您的请假记录将显示在这里</text>
    </view>
    
    <view class="history-list" wx:else>
      <view class="history-card" wx:for="{{historyList}}" wx:key="id">
        <view class="history-card-header">
          <view class="type-badge">
            <view class="type-dot"></view>
            <text class="type-text">{{item.leave_type}}</text>
          </view>
          <view class="status-badge status-{{item.status}}">
            <text>{{statusMap[item.status] || '处理中'}}</text>
          </view>
        </view>
        
        <view class="history-card-body">
          <view class="info-row">
            <view class="info-icon">
              <image src="/assets/CodeBubbyAssets/5_4/9.svg" mode="aspectFit"></image>
            </view>
            <view class="info-content">
              <text class="info-label">请假时间</text>
              <text class="info-value">{{item.start_formatted}} <text class="time-separator">至</text> {{item.end_formatted}}</text>
            </view>
          </view>
          
          <view class="info-row align-start">
            <view class="info-icon">
              <image src="/assets/CodeBubbyAssets/5_4/15.svg" mode="aspectFit"></image>
            </view>
            <view class="info-content">
              <text class="info-label">事由说明</text>
              <text class="info-value reason-text">{{item.reason}}</text>
            </view>
          </view>
        </view>
        
        <view class="history-card-footer">
          <text class="submit-time">提交于 {{item.created_formatted}}</text>
        </view>
      </view>

      <view class="loading-state" wx:if="{{isLoadingMore}}">
        <view class="loading-spinner"></view>
        <text>加载更多...</text>
      </view>
      <view class="no-more-state" wx:elif="{{historyList.length > 0 && !hasMore}}">
        <view class="line"></view>
        <text>到底啦</text>
        <view class="line"></view>
      </view>
    </view>
  </view>
  
</view>
