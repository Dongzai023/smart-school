.container {
  min-height: 100vh;
  background-color: #F8FAFC;
  padding-bottom: 80rpx;
  position: relative;
}

/* 顶部背景设计 */
.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 420rpx;
  background: linear-gradient(135deg, #00BC7D 0%, #009D68 100%);
  z-index: 0;
  overflow: hidden;
}

.bg-shape {
  position: absolute;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.shape-1 {
  width: 400rpx;
  height: 400rpx;
  top: -100rpx;
  right: -100rpx;
}

.shape-2 {
  width: 200rpx;
  height: 200rpx;
  bottom: 50rpx;
  left: -50rpx;
}

/* 页面标题 */
.page-header {
  position: relative;
  z-index: 1;
  padding: 60rpx 40rpx 40rpx;
  color: #FFFFFF;
}

.header-title {
  font-size: 48rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  margin-bottom: 8rpx;
}

.header-subtitle {
  font-size: 20rpx;
  opacity: 0.7;
  font-weight: 500;
  letter-spacing: 4rpx;
}

/* Tab 切换 */
.tabs {
  position: relative;
  z-index: 1;
  display: flex;
  margin: 0 40rpx 40rpx;
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(10px);
  border-radius: 20rpx;
  padding: 8rpx 20rpx;
}

.tab-item {
  flex: 1;
  position: relative;
}

.tab-content {
  padding: 24rpx 20rpx;
  text-align: center;
  position: relative;
  z-index: 2;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.tab-text {
  font-size: 28rpx;
  color: #FFFFFF;
  opacity: 0.8;
  font-weight: 500;
}

.tab-item.active .tab-content {
  color: #00BC7D;
  background: #FFFFFF;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.tab-item.active .tab-text {
  opacity: 1;
  color: #00BC7D;
  font-weight: 600;
}

/* 表单主体内容区 */
.content-wrapper {
  position: relative;
  z-index: 1;
  padding: 0 32rpx;
  width: 90%;
}

.card-box {
  background: #FFFFFF;
  border-radius: 32rpx;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.04);
  padding: 48rpx 40rpx;
  margin-bottom: 40rpx;
  width: 88%;
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 48rpx;
}

.card-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  background: #E6F8F2;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.card-icon {
  width: 32rpx;
  height: 32rpx;
}

.card-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1E293B;
}

/* 表单样式 */
.form-group {
  margin-bottom: 40rpx;
}

.form-label {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  padding-left: 4rpx;
}

.label-text {
  font-size: 28rpx;
  color: #475569;
  font-weight: 500;
}

.required-star {
  color: #F43F5E;
  margin-left: 8rpx;
  font-size: 24rpx;
}

.picker-view {
  width: 100%;
  height: 96rpx;
  background: #F8FAFC;
  border-radius: 16rpx;
  padding: 0 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.picker-view.has-value {
  background: #FFFFFF;
  border-color: #E2E8F0;
}

.picker-text {
  font-size: 28rpx;
  color: #94A3B8;
}

.has-value .picker-text {
  color: #1E293B;
}

.picker-arrow {
  width: 24rpx;
  height: 24rpx;
  opacity: 0.4;
}

.datetime-group {
  display: flex;
  gap: 20rpx;
}

.datetime-picker {
  flex: 1;
}

/* 文本域 */
.textarea-wrap {
  position: relative;
  background: #F8FAFC;
  border-radius: 16rpx;
  padding: 24rpx;
  border: 2rpx solid transparent;
}

.form-textarea {
  width: 100%;
  height: 240rpx;
  font-size: 28rpx;
  color: #1E293B;
  box-sizing: border-box;
  line-height: 1.6;
}

.textarea-placeholder {
  color: #94A3B8;
}

.word-count {
  position: absolute;
  bottom: 20rpx;
  right: 24rpx;
  font-size: 22rpx;
  color: #94A3B8;
}

/* 提交按钮 */
.submit-wrap {
  padding-top: 24rpx;
}

.submit-btn {
  width: 100% !important;
  height: 104rpx;
  background: linear-gradient(135deg, #00BC7D 0%, #009D68 100%);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 32rpx rgba(0, 188, 125, 0.24);
  margin: 0;
  padding: 0;
}

.submit-btn::after {
  border: none;
}

/* 历史卡片设计 */
.history-card {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.02);
  border: 1rpx solid #F1F5F9;
}

.history-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
}

.type-badge {
  display: flex;
  align-items: center;
  background: #F1F5F9;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.type-dot {
  width: 12rpx;
  height: 12rpx;
  background: #00BC7D;
  border-radius: 50%;
  margin-right: 12rpx;
}

.type-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #475569;
}

.status-badge {
  font-size: 24rpx;
  font-weight: 600;
  padding: 6rpx 20rpx;
  border-radius: 12rpx;
}

.status-pending { background: #FFFBEB; color: #D97706; }
.status-approved { background: #ECFDF5; color: #059669; }
.status-rejected { background: #FEF2F2; color: #DC2626; }

.history-card-body {
  margin-bottom: 24rpx;
}

.info-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.info-row.align-start {
  align-items: flex-start;
}

.info-icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  opacity: 0.6;
}

.info-icon image {
  width: 28rpx;
  height: 28rpx;
}

.info-content {
  flex: 1;
}

.info-label {
  font-size: 22rpx;
  color: #94A3B8;
  display: block;
  margin-bottom: 4rpx;
}

.info-value {
  font-size: 26rpx;
  color: #334155;
  font-weight: 500;
}

.time-separator {
  color: #CBD5E1;
  margin: 0 8rpx;
  font-weight: normal;
}

.reason-text {
  line-height: 1.6;
  white-space: pre-wrap;
}

.history-card-footer {
  border-top: 1rpx solid #F8FAFC;
  padding-top: 20rpx;
  display: flex;
  justify-content: flex-end;
}

.submit-time {
  font-size: 22rpx;
  color: #94A3B8;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon-wrap {
  width: 240rpx;
  height: 240rpx;
  background: #FFFFFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 20rpx 40rpx rgba(0, 0, 0, 0.03);
  margin-bottom: 40rpx;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  opacity: 0.3;
}

.empty-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #475569;
  margin-bottom: 12rpx;
}

.empty-subtext {
  font-size: 26rpx;
  color: #94A3B8;
}

/* 加载更多与无更多 */
.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
  color: #94A3B8;
  font-size: 24rpx;
}

.loading-spinner {
  width: 24rpx;
  height: 24rpx;
  border: 3rpx solid #E2E8F0;
  border-top-color: #00BC7D;
  border-radius: 50%;
  margin-right: 12rpx;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.no-more-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
  color: #CBD5E1;
  font-size: 22rpx;
}

.no-more-state .line {
  width: 60rpx;
  height: 2rpx;
  background: #E2E8F0;
  margin: 0 20rpx;
}

/* 底部信息 */
.footer {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0;
  opacity: 0.4;
}

.footer-icon {
  width: 64rpx;
  height: 4rpx;
  margin-bottom: 24rpx;
}

.footer-title {
  font-size: 20rpx;
  font-family: Inter, sans-serif;
  font-weight: 900;
  color: #0F172B;
  margin-bottom: 12rpx;
}

.footer-subtitle {
  font-size: 18rpx;
  font-family: Inter, sans-serif;
  font-weight: 700;
  color: #62748E;
}

.bottom-safe-area {
  height: 100rpx;
}
footer-copyright{
  font-size: 9rpx;
  color: #62748E;
}