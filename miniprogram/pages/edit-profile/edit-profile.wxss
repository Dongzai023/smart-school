.container {
  min-height: 100vh;
  background-color: #F8FAFC;
  padding-bottom: 40rpx;
}

.header-bg {
  height: 200rpx;
  background: #00BC7D;
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  z-index: 0;
}

.form-card {
  position: relative;
  z-index: 1;
  background: #FFFFFF;
  border-radius: 24rpx;
  margin: 40rpx 32rpx;
  padding: 40rpx 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.form-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1E293B;
  margin-bottom: 40rpx;
  text-align: center;
}

.form-section-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #64748B;
  margin: 48rpx 0 24rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid #F1F5F9;
}

.form-group {
  margin-bottom: 32rpx;
}

.switch-group {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
}

.form-label {
  font-size: 28rpx;
  color: #475569;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.form-input, .picker-view {
  width: 100%;
  height: 88rpx;
  background: #F8FAFC;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #1E293B;
  box-sizing: border-box;
  display: flex;
  align-items: center;
}

.placeholder-text {
  color: #94A3B8;
}

.btn-group {
  margin-top: 64rpx;
  display: flex;
  gap: 24rpx;
}

.cancel-btn, .save-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cancel-btn {
  background: #F1F5F9;
  color: #475569;
}

.save-btn {
  background: #00BC7D;
  color: #FFFFFF;
}

.cancel-btn::after, .save-btn::after {
  border: none;
}
