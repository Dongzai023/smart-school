<view class="container">
  <view class="header-bg"></view>

  <view class="form-card">
    <view class="form-title">完善个人信息</view>
    
    <form bindsubmit="submitForm">
      <!-- 基本信息 -->
      <view class="form-group">
        <view class="form-label">姓名</view>
        <input class="form-input" name="name" value="{{userInfo.name}}" placeholder="请输入真实姓名" />
      </view>
      
      <view class="form-group">
        <view class="form-label">昵称</view>
        <input class="form-input" name="nickname" value="{{userInfo.nickname}}" placeholder="请输入昵称" />
      </view>

      <view class="form-group">
        <view class="form-label">性别</view>
        <picker mode="selector" range="{{genderOptions}}" value="{{genderIndex}}" bindchange="onGenderChange">
          <view class="picker-view {{genderIndex >= 0 ? '' : 'placeholder-text'}}">
            {{genderIndex >= 0 ? genderOptions[genderIndex] : '请选择性别'}}
          </view>
        </picker>
      </view>
      
      <view class="form-group">
        <view class="form-label">手机号码</view>
        <input class="form-input" type="number" name="phone" value="{{userInfo.phone}}" placeholder="请输入联系电话" />
      </view>

      <!-- 教学信息 -->
      <view class="form-section-title">教学信息</view>
      
      <view class="form-group">
        <view class="form-label">所属部门</view>
        <input class="form-input" name="department" value="{{userInfo.department}}" placeholder="例如：高中部 / 初中部" />
      </view>

      <view class="form-group">
        <view class="form-label">教研组</view>
        <input class="form-input" name="department_group" value="{{userInfo.department_group}}" placeholder="例如：语文组" />
      </view>

      <view class="form-group">
        <view class="form-label">任教学科</view>
        <input class="form-input" name="teaching_subject" value="{{userInfo.teaching_subject}}" placeholder="例如：语文" />
      </view>
      
      <view class="form-group">
        <view class="form-label">年级</view>
        <input class="form-input" name="grade" value="{{userInfo.grade}}" placeholder="例如：高一" />
      </view>

      <view class="form-group">
        <view class="form-label">班级</view>
        <input class="form-input" name="class_name" value="{{userInfo.class_name}}" placeholder="例如：1班" />
      </view>

      <view class="form-group switch-group">
        <view class="form-label">是否班主任</view>
        <switch name="is_headmaster" checked="{{userInfo.is_headmaster}}" color="#00BC7D" />
      </view>

      <!-- 操作按钮 -->
      <view class="btn-group">
        <button class="cancel-btn" bindtap="goBack">取消</button>
        <button class="save-btn" form-type="submit" loading="{{isSaving}}">保存信息</button>
      </view>
    </form>
  </view>
</view>
