# 希沃一体机管理系统 — 环境变量配置
# 复制此文件为 .env 并修改值

# ===== 应用配置 =====
DEBUG=false

# ===== 数据库 =====
DB_HOST=db
DB_PORT=3306
DB_USER=lock_screen
DB_PASSWORD=请修改为强密码
DB_NAME=lock_screen
MYSQL_ROOT_PASSWORD=请修改为强密码

# ===== Redis =====
REDIS_HOST=redis
REDIS_PORT=6379

# ===== JWT 密钥 (请生成随机字符串) =====
# 可用命令生成: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=请修改为随机密钥

# ===== 文件上传 =====
MAX_IMAGE_SIZE=5242880

# ===== 服务器域名/IP (用于Agent连接) =====
SERVER_HOST=your-server-ip-or-domain
